<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>  منصة إنجاز  </title>
    <link
        href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700&family=Amiri:wght@400;700&display=swap"
        rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Tajawal', sans-serif;
            min-height: 100vh;
            background: #c6a6e5;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        /* ====== CARD ====== */
        .card {
            background: #ffffff;
            border-radius: 24px;
            padding: 48px 44px;
            width: 100%;
            max-width: 400px;
            box-shadow: 0 8px 40px rgba(180, 80, 140, 0.12);
            text-align: center;
            animation: slideUp 0.4s ease;
        }

        @@keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ====== LOGO ====== */
        .logo {
            font-size: 2.5rem;
            margin-bottom: 10px;
        }

        /* ====== TITLE ====== */
        .title {
            font-family: 'Amiri', serif;
            font-size: 2rem;
            font-weight: 700;
            color: #7b2d8b;
            margin-bottom: 30px;
            line-height: 1.3;
            letter-spacing: 0.5px;
        }

        /* ====== INPUTS ====== */
        .input-group {
            margin-bottom: 14px;
        }

        .input-group input {
            width: 100%;
            padding: 13px 18px;
            border: 1.5px solid #e8cff0;
            border-radius: 12px;
            font-family: 'Tajawal', sans-serif;
            font-size: 0.95rem;
            color: #333;
            background: #fdf7ff;
            outline: none;
            text-align: right;
            direction: rtl;
            transition: border-color 0.25s, box-shadow 0.25s;
        }

        .input-group input::placeholder {
            color: #c4a0d0;
        }

        .input-group input:focus {
            border-color: #9c3fbe;
            box-shadow: 0 0 0 3px rgba(156, 63, 190, 0.1);
            background: #fff;
        }

        /* ====== ROLE SELECTOR ====== */
        .role-selector {
            text-align: right;
            margin-bottom: 20px;
        }

        .role-selector>label {
            display: block;
            font-size: 0.9rem;
            color: #7b2d8b;
            margin-bottom: 10px;
            font-weight: 600;
        }

        .role-options {
            display: flex;
            gap: 12px;
        }

        .role-card {
            flex: 1;
            padding: 14px 10px;
            border: 2px solid #e8cff0;
            border-radius: 14px;
            text-align: center;
            cursor: pointer;
            transition: all 0.2s;
            background: #fdf7ff;
        }

        .role-card input[type="radio"] {
            display: none;
        }

        .role-card:has(input:checked) {
            border-color: #9c3fbe;
            background: rgba(156, 63, 190, 0.07);
        }

        .role-icon {
            font-size: 1.8rem;
            margin-bottom: 4px;
        }

        .role-label {
            font-size: 0.88rem;
            font-weight: 600;
            color: #5a2070;
        }

        /* ====== BUTTON ====== */
        .btn {
            width: 100%;
            padding: 14px;
            margin-top: 8px;
            background: #9c3fbe;
            color: white;
            border: none;
            border-radius: 12px;
            font-family: 'Tajawal', sans-serif;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.25s, transform 0.15s, box-shadow 0.25s;
            letter-spacing: 0.3px;
        }

        .btn:hover {
            background: #7b2d8b;
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(123, 45, 139, 0.3);
        }

        .btn:active {
            transform: translateY(0);
        }

        /* ====== SWITCH LINK ====== */
        .switch-link {
            margin-top: 20px;
            font-size: 0.88rem;
            color: #888;
        }

        .switch-link a {
            color: #9c3fbe;
            font-weight: 600;
            text-decoration: none;
            transition: color 0.2s;
        }

        .switch-link a:hover {
            color: #7b2d8b;
            text-decoration: underline;
        }

        /* ====== TOAST ====== */
        .toast {
            position: fixed;
            bottom: 24px;
            left: 50%;
            transform: translateX(-50%) translateY(80px);
            background: #333;
            color: white;
            padding: 11px 24px;
            border-radius: 25px;
            font-size: 0.9rem;
            font-family: 'Tajawal', sans-serif;
            z-index: 9999;
            transition: transform 0.3s ease;
            white-space: nowrap;
        }

        .toast.show {
            transform: translateX(-50%) translateY(0);
        }

        .toast.success {
            background: #27ae60;
        }

        .toast.error {
            background: #e74c3c;
        }

        /* ====== RESPONSIVE ====== */
        @@media (max-width: 480px) {
            .card {
                padding: 36px 24px;
            }

            .role-options {
                flex-direction: column;
            }
        }
    </style>
</head>

<body>
    <div class="card">
        <div class="logo">📚</div>
        <h1 class="title">مَنصة أنجاز</h1>

        <!-- Login Form -->
        <div id="login-view">
            <div class="input-group">
                <input type="email" id="login-email" placeholder="البريد الإلكتروني">
            </div>
            <div class="input-group">
                <input type="password" id="login-password" placeholder="كلمة المرور">
            </div>

            <div class="role-selector">
                <label>أنت:</label>
                <div class="role-options">
                    <label class="role-card">
                        <input type="radio" name="role" value="student" checked>
                        <div class="role-icon">🎓</div>
                        <div class="role-label">طالب</div>
                    </label>
                    <label class="role-card">
                        <input type="radio" name="role" value="doctor">
                        <div class="role-icon">👨‍🏫</div>
                        <div class="role-label">دكتور</div>
                    </label>
                </div>
            </div>

            <button class="btn" id="login-btn">تسجيل الدخول</button>
            <p class="switch-link">
                ليس لديك حساب؟ <a href="#" id="show-signup">إنشاء حساب جديد</a>
            </p>
        </div>

        <!-- Signup Form -->
        <div id="signup-view" style="display:none">
            <div class="input-group">
                <input type="text" id="signup-name" placeholder="الاسم الكامل">
            </div>
            <div class="input-group">
                <input type="email" id="signup-email" placeholder="البريد الإلكتروني">
            </div>
            <div class="input-group">
                <input type="password" id="signup-password" placeholder="كلمة المرور">
            </div>

            <div class="role-selector">
                <label>نوع الحساب:</label>
                <div class="role-options">
                    <label class="role-card">
                        <input type="radio" name="role" value="student" checked>
                        <div class="role-icon">🎓</div>
                        <div class="role-label">طالب</div>
                    </label>
                    <label class="role-card">
                        <input type="radio" name="role" value="doctor">
                        <div class="role-icon">👨‍🏫</div>
                        <div class="role-label">دكتور</div>
                    </label>
                </div>
            </div>

            <button class="btn" id="signup-btn">إنشاء حساب</button>
            <p class="switch-link">
                لديك حساب؟ <a href="#" id="show-login">تسجيل الدخول</a>
            </p>
        </div>
    </div>

    <!-- Toast -->
    <div id="toast" class="toast"></div>

    <script>
        // Safe fallback if Firebase not loaded
        if (typeof auth === 'undefined') var auth = null;
        if (typeof db === 'undefined') var db = null;

        // ====== DOM ======
        const loginView = document.getElementById('login-view');
        const signupView = document.getElementById('signup-view');
        const showSignup = document.getElementById('show-signup');
        const showLogin = document.getElementById('show-login');

        const loginEmail = document.getElementById('login-email');
        const loginPassword = document.getElementById('login-password');
        const loginBtn = document.getElementById('login-btn');

        const signupName = document.getElementById('signup-name');
        const signupEmail = document.getElementById('signup-email');
        const signupPassword = document.getElementById('signup-password');
        const signupBtn = document.getElementById('signup-btn');

        // ====== SWITCH FORMS ======
        showSignup.addEventListener('click', (e) => {
            e.preventDefault();
            loginView.style.display = 'none';
            signupView.style.display = 'block';
        });

        showLogin.addEventListener('click', (e) => {
            e.preventDefault();
            signupView.style.display = 'none';
            loginView.style.display = 'block';
        });

        // ====== LOGIN ======
        loginBtn.addEventListener('click', async () => {
            const email = loginEmail.value.trim();
            const password = loginPassword.value;

            if (!email || !password) { showToast('أدخل البريد وكلمة المرور', 'error'); return; }

            loginBtn.textContent = '...';
            loginBtn.disabled = true;

            try {
                // For now, allow any login (Backend offline mode)
                const name = email.split('@@')[0];
                const role = document.querySelector('input[name="role"]:checked')?.value || 'student';

                const userData = {
                    email,
                    name,
                    avatar: null,
                    role,
                    loginTime: new Date().toISOString()
                };

                // Use same keys as auth-guard expects
                localStorage.setItem('sl_user', JSON.stringify(userData));
                localStorage.setItem('sl_token', btoa(email + ':' + new Date().getTime()));
                localStorage.setItem('enjaz_user', JSON.stringify(userData));
                localStorage.setItem('enjaz_token', btoa(email + ':' + new Date().getTime())); // Simple token

                showToast('أهلاً بك! ✨', 'success');
        const redirectUrl = role === 'doctor' ? '/Doctor/Dashboard' : '/Student/Dashboard';                setTimeout(() => window.location.href = redirectUrl, 900);
            } catch (err) {
                // Fallback: offline mode
                const name = email.split('@@')[0];
                const role = document.querySelector('input[name="role"]:checked')?.value || 'student';
                const userData = {
                    email,
                    name,
                    avatar: null,
                    role,
                    loginTime: new Date().toISOString()
                };

                localStorage.setItem('sl_user', JSON.stringify(userData));
                localStorage.setItem('sl_token', btoa(email + ':' + new Date().getTime()));
                localStorage.setItem('enjaz_user', JSON.stringify(userData));
                localStorage.setItem('enjaz_token', btoa(email + ':' + new Date().getTime()));
                showToast('أهلاً بك! ✨', 'success');
                const redirectUrl = role === 'doctor' ? 'DoctorHome.html' : 'StudentHome.html';
                setTimeout(() => window.location.href = redirectUrl, 900);
            } finally {
                loginBtn.textContent = 'تسجيل الدخول';
                loginBtn.disabled = false;
            }
        });

        // Enter key on login
        loginPassword.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') loginBtn.click();
        });

        // ====== SIGNUP ======
        signupBtn.addEventListener('click', async () => {
            const name = signupName.value.trim();
            const email = signupEmail.value.trim();
            const password = signupPassword.value;

            if (!name || !email || !password) { showToast('أكمل جميع الحقول', 'error'); return; }
            if (password.length < 6) { showToast('كلمة المرور 6 أحرف على الأقل', 'error'); return; }

            signupBtn.textContent = '...';
            signupBtn.disabled = true;

            try {
                const role = document.querySelector('input[name="role"]:checked')?.value || 'student';

                const userData = {
                    email,
                    name,
                    avatar: null,
                    role,
                    createdAt: new Date().toISOString()
                };

                // Use same keys as auth-guard expects
                localStorage.setItem('sl_user', JSON.stringify(userData));
                localStorage.setItem('sl_token', btoa(email + ':' + new Date().getTime()));
                localStorage.setItem('enjaz_user', JSON.stringify(userData));
                localStorage.setItem('enjaz_token', btoa(email + ':' + new Date().getTime())); // Simple token

                showToast('تم إنشاء الحساب! 🎉', 'success');
                const redirectUrl = role === 'doctor' ? 'DoctorHome.html' : 'StudentHome.html';
                setTimeout(() => window.location.href = redirectUrl, 900);
            } catch (err) {
                // Fallback create
                const role = document.querySelector('input[name="role"]:checked')?.value || 'student';
                const userData = {
                    email,
                    name,
                    avatar: null,
                    role,
                    createdAt: new Date().toISOString()
                };

                localStorage.setItem('sl_user', JSON.stringify(userData));
                localStorage.setItem('sl_token', btoa(email + ':' + new Date().getTime()));
                localStorage.setItem('enjaz_user', JSON.stringify(userData));
                localStorage.setItem('enjaz_token', btoa(email + ':' + new Date().getTime()));

                showToast('تم إنشاء الحساب! 🎉', 'success');
                const redirectUrl = role === 'doctor' ? 'DoctorHome.html' : 'StudentHome.html';
                setTimeout(() => window.location.href = redirectUrl, 900);
            } finally {
                signupBtn.textContent = 'إنشاء حساب';
                signupBtn.disabled = false;
            }
        });

        // Enter key on signup
        signupPassword.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') signupBtn.click();
        });

        // ====== TOAST ======
        function showToast(msg, type = 'info') {
            const toast = document.getElementById('toast');
            toast.textContent = msg;
            toast.className = `toast ${type} show`;
            setTimeout(() => toast.classList.remove('show'), 3000);
        }
    </script>
</body>

</html>