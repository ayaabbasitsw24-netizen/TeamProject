    <!-- ══════════ MODAL: ADD/EDIT ASSIGNMENT (Doctor) ══════════ -->
    <div class="modal-overlay" id="assign-modal">
        <div class="modal-card">
            <h3><i class="fas fa-file-plus"></i> <span id="modal-title-text">إضافة تكليف جديد</span></h3>

            <div class="form-group">
                <label>عنوان التكليف *</label>
                <input type="text" id="assign-title" placeholder="مثال: واجب الفصل الثالث - خوارزميات الفرز">
            </div>
            <div class="form-group">
                <label>الوصف والتعليمات *</label>
                <textarea id="assign-desc" rows="4" placeholder="اكتب تعليمات التكليف بالتفصيل..."></textarea>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>المادة الدراسية</label>
                    <input type="text" id="assign-subject" placeholder="مثال: برمجة، شبكات...">
                </div>
                <div class="form-group">
                    <label>الأولوية</label>
