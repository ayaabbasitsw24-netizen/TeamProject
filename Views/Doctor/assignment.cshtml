                    <p>اسحب الملف هنا أو انقر للاختيار</p>
                    <p style="font-size:0.78rem;margin-top:4px;">(PDF، Word، صور)</p>
                    <input type="file" id="submit-file" accept=".pdf,.doc,.docx,.jpg,.jpeg,.png">
                    <div class="file-chosen" id="file-chosen-name" style="display:none;"></div>
                </div>
            </div>

            <div class="modal-actions">
                <button class="btn-secondary" id="cancel-submit-btn">إلغاء</button>
                <button class="btn-primary" id="confirm-submit-btn"><i class="fas fa-check"></i> تأكيد التسليم</button>
            </div>
        </div>
    </div>

    <!-- ══════════ MODAL: VIEW SUBMISSIONS (Doctor) ══════════ -->
    <div class="modal-overlay" id="submissions-modal">
        <div class="modal-card" style="max-width:650px;">
            <h3><i class="fas fa-users"></i> تسليمات الطلاب</h3>
            <div style="font-size:0.88rem;color:var(--text-muted);margin-bottom:16px;" id="submissions-assign-title"></div>
            <div id="submissions-list"></div>
            <div class="modal-actions">
                <button class="btn-secondary" id="close-submissions-btn">إغلاق</button>
            </div>
        </div>
    </div>

    <!-- Toast -->
    <div id="toast" class="toast"></div>

    <script>
        // ══════════════════════════════════════════════
        //  Helpers
        // ══════════════════════════════════════════════
        function getLS(key, fallback) {
            try { return JSON.parse(localStorage.getItem(key)) ?? fallback; }
            catch { return fallback; }
        }
        function setLS(key, val) {
            try { localStorage.setItem(key, JSON.stringify(val)); } catch {}
        }

        function showToast(msg, type = 'success') {
            const t = document.getElementById('toast');
            t.textContent = msg;
            t.className = `toast ${type}`;
            t.classList.add('show');
            setTimeout(() => t.classList.remove('show'), 3200);
        }

        function formatDate(dateStr) {
            if (!dateStr) return '—';
            const d = new Date(dateStr);
            return d.toLocaleDateString('ar-EG', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
        }

        function dueBadge(dateStr) {
            if (!dateStr) return '';
            const due = new Date(dateStr);
            const now = new Date();
            const diff = Math.ceil((due - now) / (1000 * 60 * 60 * 24));
            let cls = 'tag-due', label = `📅 ${formatDate(dateStr)}`;
            if (diff < 0) { cls = 'tag-due overdue'; label = `⚠️ فات الموعد`; }
            else if (diff <= 3) { cls = 'tag-due soon'; label = `⏰ باقي ${diff} يوم`; }
            return `<span class="assign-tag ${cls}">${label}</span>`;
        }

        function priorityBadge(p) {
            if (p === 'urgent') return `<span class="assign-tag tag-urgent">🔴 عاجل</span>`;
            if (p === 'low') return `<span class="assign-tag tag-low">⚪ منخفض</span>`;
            return `<span class="assign-tag tag-normal">🟢 عادي</span>`;
        }

        // ══════════════════════════════════════════════
        //  State
        // ══════════════════════════════════════════════
        let currentUser = null;
        let isDoctor = false;
        let assignments = [];
        let submissions = {}; // { assignId: { userId, answer, fileName, time } }
        let editingId = null;
        let currentFilter = 'all';
        let submitTargetId = null;

        // ══════════════════════════════════════════════
        //  Bootstrap
        // ══════════════════════════════════════════════
        document.addEventListener('DOMContentLoaded', () => {
            // Auth guard
            const rawUser = localStorage.getItem('enjaz_user');
            const token = localStorage.getItem('enjaz_token');
            if (!rawUser || !token) { location.href = 'login.html'; return; }

            currentUser = JSON.parse(rawUser);
            isDoctor = currentUser.role === 'doctor';

            // UI init
            document.getElementById('sidebar-name').textContent = currentUser.name;
            document.getElementById('sidebar-avatar').textContent = currentUser.name.charAt(0).toUpperCase();
            document.getElementById('header-name').textContent = currentUser.name;
            document.getElementById('header-avatar').textContent = currentUser.name.charAt(0).toUpperCase();
            document.getElementById('sidebar-role').textContent = isDoctor ? 'دكتور' : 'طالب';

            // Theme
            const profile = getLS('enjaz_profile', { theme: 'purple' });
            document.body.className = `theme-${profile.theme || 'purple'}`;

            // Role banner
            if (isDoctor) {
                document.getElementById('role-banner').style.display = 'flex';
                document.getElementById('add-assign-btn').style.display = 'inline-flex';
                document.getElementById('lbl-pending').textContent = 'بانتظار التسليم';
                document.getElementById('lbl-submitted').textContent = 'تم استلامها';
                // Hide student-only filter labels (submitted filter still useful for doctor)
            } else {
                document.getElementById('role-banner-student').style.display = 'flex';
            }

            // Load data
            assignments = getLS('enjaz_assignments', getDemoAssignments());
            submissions = getLS('enjaz_submissions', {});

            renderAll();
            bindEvents();
        });

        // ══════════════════════════════════════════════
        //  Demo seed assignments
        // ══════════════════════════════════════════════
        function getDemoAssignments() {
            const today = new Date();
            const future3 = new Date(today); future3.setDate(today.getDate() + 3);
            const future10 = new Date(today); future10.setDate(today.getDate() + 10);
            const past = new Date(today); past.setDate(today.getDate() - 2);

            return [
                {
                    id: 'a1', title: 'تقرير خوارزميات الفرز',
                    desc: 'قم بكتابة تقرير يشرح الفرق بين خوارزميات الفرز التالية: Bubble Sort، Quick Sort، Merge Sort. مع تحليل التعقيد الزمني لكل منها وتطبيق أمثلة برمجية.',
                    subject: 'برمجة', priority: 'urgent',
                    due: future3.toISOString().split('T')[0],
                    grade: 20, notes: 'يُسلَّم ملف PDF فقط',
                    doctorName: 'د. الرشيدي', createdAt: new Date().toISOString()
                },
                {
                    id: 'a2', title: 'بحث في قواعد البيانات العلائقية',
                    desc: 'اكتب بحثاً علمياً عن قواعد البيانات العلائقية مقارنةً بقواعد البيانات غير العلائقية. يجب أن يشمل البحث: التعريف، المميزات، العيوب، وأمثلة على كلٍّ منهما.',
                    subject: 'قواعد البيانات', priority: 'normal',
                    due: future10.toISOString().split('T')[0],
                    grade: 15, notes: '',
                    doctorName: 'د. الرشيدي', createdAt: new Date().toISOString()
                },
                {
                    id: 'a3', title: 'تمارين الشبكات الفصل الثالث',
                    desc: 'حل جميع تمارين الفصل الثالث من الكتاب المقرر (الصفحات 120-145). مع إظهار خطوات الحل بالتفصيل.',
                    subject: 'شبكات الحاسوب', priority: 'low',
                    due: past.toISOString().split('T')[0],
                    grade: 10, notes: 'الواجب التأخر يُخصم ربع الدرجة لكل يوم',
                    doctorName: 'د. الرشيدي', createdAt: new Date().toISOString()
                }
            ];
        }

        // ══════════════════════════════════════════════
        //  Render
        // ══════════════════════════════════════════════
        function renderAll() {
            updateStats();
            renderGrid();
        }

        function getAssignStatus(a) {
            const due = new Date(a.due);
            const now = new Date();
            const sub = submissions[a.id];
            const submittedByMe = sub && (!isDoctor) && sub.userId === currentUser.id;
            const isOverdue = due < now;

            if (submittedByMe) return 'submitted';
            if (isOverdue) return 'overdue';
            return 'pending';
        }

        function updateStats() {
            const total = assignments.length;
            let pending = 0, submitted = 0, overdue = 0;
            assignments.forEach(a => {
                const st = getAssignStatus(a);
                if (st === 'pending') pending++;
                else if (st === 'submitted') submitted++;
                else if (st === 'overdue') overdue++;
            });
            document.getElementById('stat-total').textContent = total;
            document.getElementById('stat-pending').textContent = pending;
            document.getElementById('stat-submitted').textContent = submitted;
            document.getElementById('stat-overdue').textContent = overdue;
        }

        function renderGrid() {
            const grid = document.getElementById('assignments-grid');
            const searchQuery = document.getElementById('search-box').value.toLowerCase();

            let list = assignments.filter(a => {
                const status = getAssignStatus(a);
                const matchFilter = currentFilter === 'all' || status === currentFilter;
                const matchSearch = !searchQuery ||
                    a.title.toLowerCase().includes(searchQuery) ||
                    a.subject.toLowerCase().includes(searchQuery) ||
                    a.desc.toLowerCase().includes(searchQuery);
                return matchFilter && matchSearch;
            });

            if (list.length === 0) {
                grid.innerHTML = `
                    <div class="empty-state">
                        <div class="empty-icon">📭</div>
                        <h3>لا توجد تكاليف هنا</h3>
                        <p>${isDoctor ? 'انقر على "إضافة تكليف جديد" لإنشاء أول تكليف.' : 'لم يُرسل إليك الدكتور أي تكليف بعد.'}</p>
                    </div>`;
                return;
            }

            grid.innerHTML = list.map(a => renderCard(a)).join('');
        }

        function renderCard(a) {
            const status = getAssignStatus(a);
            const sub = submissions[a.id];
            const submittedByMe = sub && !isDoctor && sub.userId === currentUser.id;
            const subCount = sub ? (Array.isArray(sub) ? sub.length : 1) : 0;

            const icons = { برمجة: '💻', شبكات: '🌐', 'قواعد البيانات': '🗄️', 'ذكاء اصطناعي': '🤖', رياضيات: '📐', فيزياء: '⚛️' };
            const icon = icons[a.subject] || '📋';

            let actionsHTML = '';
            if (isDoctor) {
                actionsHTML = `
                    <button class="btn-secondary" onclick="openSubmissions('${a.id}')">
                        <i class="fas fa-users"></i> التسليمات (${subCount})
                    </button>
                    <div style="display:flex;gap:6px;margin-top:4px;">
                        <button class="btn-secondary" onclick="editAssignment('${a.id}')" style="padding:7px 12px;">
                            <i class="fas fa-edit"></i>
                        </button>
                        <button class="btn-danger" onclick="deleteAssignment('${a.id}')">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>`;
            } else {
                if (submittedByMe) {
                    actionsHTML = `<button class="submit-btn submitted"><i class="fas fa-check-circle"></i> تم التسليم</button>`;
                } else {
                    const expired = status === 'overdue';
                    actionsHTML = expired
                        ? `<button class="submit-btn pending" style="background:#9ca3af;cursor:not-allowed;" disabled><i class="fas fa-lock"></i> انتهى الموعد</button>`
                        : `<button class="submit-btn pending" onclick="openSubmitModal('${a.id}')"><i class="fas fa-paper-plane"></i> تسليم الواجب</button>`;
                }
            }

            const gradeTag = a.grade ? `<span class="assign-tag tag-from">🏆 ${a.grade} درجة</span>` : '';
            const notesTag = a.notes ? `<span class="assign-tag" style="background:#f0f9ff;color:#0369a1;border:1px solid #bae6fd;"><i class="fas fa-info-circle"></i> ${a.notes}</span>` : '';
            const doctorTag = `<span class="assign-tag tag-from"><i class="fas fa-user-tie"></i> ${a.doctorName || 'الدكتور'}</span>`;

            return `
            <div class="assignment-card" id="card-${a.id}">
                <div class="assign-icon">${icon}</div>
                <div class="assign-body">
                    <div class="assign-title">${a.title}</div>
                    <div class="assign-desc">${a.desc}</div>
                    <div class="assign-meta">
                        ${a.subject ? `<span class="assign-tag tag-subject"><i class="fas fa-book"></i> ${a.subject}</span>` : ''}
                        ${dueBadge(a.due)}
                        ${priorityBadge(a.priority)}
                        ${gradeTag}
                        ${doctorTag}
                        ${notesTag}
                    </div>
                </div>
                <div class="assign-actions">${actionsHTML}</div>
            </div>`;
        }

        // ══════════════════════════════════════════════
        //  Doctor: Add / Edit / Delete
        // ══════════════════════════════════════════════
        function openAddModal() {
            editingId = null;
            document.getElementById('modal-title-text').textContent = 'إضافة تكليف جديد';
            ['assign-title','assign-desc','assign-subject','assign-notes','assign-grade'].forEach(id => document.getElementById(id).value = '');
            document.getElementById('assign-priority').value = 'normal';
            document.getElementById('assign-due').value = '';
            document.getElementById('assign-modal').classList.add('open');
        }

        window.editAssignment = function(id) {
            editingId = id;
            const a = assignments.find(x => x.id === id);
            if (!a) return;
            document.getElementById('modal-title-text').textContent = 'تعديل التكليف';
            document.getElementById('assign-title').value = a.title;
            document.getElementById('assign-desc').value = a.desc;
            document.getElementById('assign-subject').value = a.subject;
            document.getElementById('assign-priority').value = a.priority;
            document.getElementById('assign-due').value = a.due;
            document.getElementById('assign-grade').value = a.grade || '';
            document.getElementById('assign-notes').value = a.notes || '';
            document.getElementById('assign-modal').classList.add('open');
        };

        function saveAssignment() {
            const title = document.getElementById('assign-title').value.trim();
            const desc = document.getElementById('assign-desc').value.trim();
            const due = document.getElementById('assign-due').value;
            if (!title || !desc || !due) { showToast('⚠️ يرجى ملء الحقول الإلزامية', 'error'); return; }

            const data = {
                id: editingId || `a${Date.now()}`,
                title,
                desc,
                subject: document.getElementById('assign-subject').value.trim() || 'عام',
                priority: document.getElementById('assign-priority').value,
                due,
                grade: parseInt(document.getElementById('assign-grade').value) || 0,
                notes: document.getElementById('assign-notes').value.trim(),
                doctorName: currentUser.name,
                createdAt: editingId ? assignments.find(x=>x.id===editingId)?.createdAt : new Date().toISOString()
            };

            if (editingId) {
                const idx = assignments.findIndex(x => x.id === editingId);
                assignments[idx] = data;
                showToast('✏️ تم تعديل التكليف بنجاح');
            } else {
                assignments.unshift(data);
                showToast('✅ تم إضافة التكليف وإرساله للطلاب');
            }

            setLS('enjaz_assignments', assignments);
            document.getElementById('assign-modal').classList.remove('open');
            renderAll();
        }

        window.deleteAssignment = function(id) {
            if (!confirm('هل أنت متأكد من حذف هذا التكليف؟')) return;
            assignments = assignments.filter(x => x.id !== id);
            setLS('enjaz_assignments', assignments);
            delete submissions[id];
            setLS('enjaz_submissions', submissions);
            showToast('🗑️ تم حذف التكليف', 'info');
            renderAll();
        };

        // ══════════════════════════════════════════════
        //  Doctor: View Submissions
        // ══════════════════════════════════════════════
        window.openSubmissions = function(id) {
            const a = assignments.find(x => x.id === id);
            document.getElementById('submissions-assign-title').textContent = `التكليف: ${a?.title}`;
            const sub = submissions[id];
            const list = document.getElementById('submissions-list');

            if (!sub || (Array.isArray(sub) && sub.length === 0)) {
                list.innerHTML = `
                    <div class="empty-state" style="padding:30px;">
                        <div class="empty-icon" style="font-size:2.5rem;">📭</div>
                        <h3>لم يُسلِّم أحد بعد</h3>
                    </div>`;
            } else {
                const entries = Array.isArray(sub) ? sub : [sub];
                list.innerHTML = entries.map(s => `
                    <div style="background:var(--bg);border-radius:12px;padding:16px;border:1px solid var(--border);margin-bottom:10px;">
                        <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">
                            <div style="width:36px;height:36px;border-radius:50%;background:var(--primary);color:white;display:flex;align-items:center;justify-content:center;font-weight:700;">
                                ${s.userName?.charAt(0) || '؟'}
                            </div>
                            <div>
                                <div style="font-weight:700;">${s.userName || 'طالب'}</div>
                                <div style="font-size:0.78rem;color:var(--text-muted);">⏰ ${s.time || '—'}</div>
                            </div>
                            <span style="margin-right:auto;padding:4px 12px;border-radius:20px;background:#dcfce7;color:#15803d;font-size:0.8rem;font-weight:700;">✅ مُسلَّم</span>
                        </div>
                        ${s.answer ? `<div style="font-size:0.88rem;color:var(--text-muted);background:var(--card-bg);border-radius:8px;padding:10px;margin-top:6px;">${s.answer}</div>` : ''}
                        ${s.fileName ? `<div style="font-size:0.8rem;margin-top:8px;color:var(--primary);"><i class="fas fa-paperclip"></i> ${s.fileName}</div>` : ''}
                    </div>
                `).join('');
            }

            document.getElementById('submissions-modal').classList.add('open');
        };

        // ══════════════════════════════════════════════
        //  Student: Submit Assignment
        // ══════════════════════════════════════════════
        window.openSubmitModal = function(id) {
            submitTargetId = id;
            const a = assignments.find(x => x.id === id);
            document.getElementById('submit-assign-title').textContent = a?.title;
            document.getElementById('submit-assign-due').textContent = `⏰ تاريخ التسليم: ${formatDate(a?.due)}`;
            document.getElementById('submit-answer').value = '';
            document.getElementById('file-chosen-name').style.display = 'none';
            document.getElementById('file-chosen-name').textContent = '';
            document.getElementById('submit-modal').classList.add('open');
        };

        function submitAssignment() {
            const answer = document.getElementById('submit-answer').value.trim();
            const fileInput = document.getElementById('submit-file');
            const fileName = fileInput.files[0]?.name || '';

            const record = {
                userId: currentUser.id,
                userName: currentUser.name,
                answer,
                fileName,
                time: new Date().toLocaleString('ar-EG')
            };

            // Store: support multiple submissions per assignment
            if (!submissions[submitTargetId]) {
                submissions[submitTargetId] = [];
            } else if (!Array.isArray(submissions[submitTargetId])) {
                submissions[submitTargetId] = [submissions[submitTargetId]];
            }
            submissions[submitTargetId].push(record);
            setLS('enjaz_submissions', submissions);

            document.getElementById('submit-modal').classList.remove('open');
            showToast('🎉 تم تسليم الواجب بنجاح!');
            renderAll();
        }

        // ══════════════════════════════════════════════
        //  Bind Events
        // ══════════════════════════════════════════════
        function bindEvents() {
            // Mobile toggle
            document.getElementById('mobile-toggle').addEventListener('click', () => {
                document.getElementById('sidebar').classList.toggle('open');
                document.getElementById('sidebar-overlay').classList.toggle('active');
            });
            document.getElementById('sidebar-overlay').addEventListener('click', () => {
                document.getElementById('sidebar').classList.remove('open');
                document.getElementById('sidebar-overlay').classList.remove('active');
            });

            // Logout
            document.getElementById('logout-btn').addEventListener('click', () => {
                localStorage.removeItem('enjaz_user');
                localStorage.removeItem('enjaz_token');
                location.href = 'login.html';
            });

            // Add assignment
            document.getElementById('add-assign-btn').addEventListener('click', openAddModal);

            // Save assignment modal
            document.getElementById('save-assign-btn').addEventListener('click', saveAssignment);
            document.getElementById('cancel-assign-btn').addEventListener('click', () => {
                document.getElementById('assign-modal').classList.remove('open');
            });
            document.getElementById('assign-modal').addEventListener('click', (e) => {
                if (e.target === document.getElementById('assign-modal'))
                    document.getElementById('assign-modal').classList.remove('open');
            });

            // Submit modal
            document.getElementById('cancel-submit-btn').addEventListener('click', () => {
                document.getElementById('submit-modal').classList.remove('open');
            });
            document.getElementById('confirm-submit-btn').addEventListener('click', submitAssignment);
            document.getElementById('submit-modal').addEventListener('click', (e) => {
                if (e.target === document.getElementById('submit-modal'))
                    document.getElementById('submit-modal').classList.remove('open');
            });

            // File drop zone
            const dropZone = document.getElementById('file-drop-zone');
            const fileInput = document.getElementById('submit-file');
            dropZone.addEventListener('click', () => fileInput.click());
            fileInput.addEventListener('change', () => {
                const name = fileInput.files[0]?.name;
                if (name) {
                    const el = document.getElementById('file-chosen-name');
                    el.textContent = `📎 ${name}`;
                    el.style.display = 'block';
                }
            });
            dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('dragover'); });
            dropZone.addEventListener('dragleave', () => dropZone.classList.remove('dragover'));
            dropZone.addEventListener('drop', (e) => {
                e.preventDefault();
                dropZone.classList.remove('dragover');
                fileInput.files = e.dataTransfer.files;
                const name = fileInput.files[0]?.name;
                if (name) {
                    const el = document.getElementById('file-chosen-name');
                    el.textContent = `📎 ${name}`;
                    el.style.display = 'block';
                }
            });

            // Submissions close
            document.getElementById('close-submissions-btn').addEventListener('click', () => {
                document.getElementById('submissions-modal').classList.remove('open');
            });
            document.getElementById('submissions-modal').addEventListener('click', (e) => {
                if (e.target === document.getElementById('submissions-modal'))
                    document.getElementById('submissions-modal').classList.remove('open');
            });

            // Filters
            document.querySelectorAll('.filter-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    currentFilter = btn.dataset.filter;
                    renderGrid();
                });
            });

            // Search
            document.getElementById('search-box').addEventListener('input', renderGrid);
        }
    </script>
</body>

</html>
