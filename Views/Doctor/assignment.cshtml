            </div>

            <div class="form-group">
                <label>ملاحظات إضافية</label>
                <input type="text" id="assign-notes" placeholder="أي ملاحظات أو تنبيهات...">
            </div>

            <div class="modal-actions">
                <button class="btn-secondary" id="cancel-assign-btn">إلغاء</button>
                <button class="btn-primary" id="save-assign-btn"><i class="fas fa-save"></i> حفظ التكليف</button>
            </div>
        </div>
    </div>

    <!-- ══════════ MODAL: SUBMIT ASSIGNMENT (Student) ══════════ -->
    <div class="modal-overlay" id="submit-modal">
        <div class="modal-card">
            <h3><i class="fas fa-paper-plane"></i> تسليم التكليف</h3>

            <div style="background:var(--accent-bg);border-radius:12px;padding:14px;margin-bottom:20px;border:1px solid var(--primary-light);">
                <div style="font-weight:700;" id="submit-assign-title">عنوان التكليف</div>
                <div style="font-size:0.82rem;color:var(--text-muted);margin-top:4px;" id="submit-assign-due"></div>
            </div>

            <div class="form-group">
                <label>إجابتك / ملاحظاتك</label>
                <textarea id="submit-answer" rows="4" placeholder="اكتب إجابتك أو ملاحظاتك هنا..."></textarea>
            </div>

            <div class="form-group">
                <label>رفع ملف (اختياري)</label>
                <div class="file-drop-zone" id="file-drop-zone">
