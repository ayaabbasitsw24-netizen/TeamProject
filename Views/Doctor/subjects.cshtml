    <!-- SignalR Client -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

    <script>
        // ── API inline ──
        const _BASE = `http://${window.location.hostname}:5059/api`;
        function _getToken() { return localStorage.getItem('sl_token') || '' }
        async function _req(method, path, body = null) { const h = { 'Content-Type': 'application/json', 'Authorization': `Bearer ${_getToken()}` }; const o = { method, headers: h }; if (body) o.body = JSON.stringify(body); try { const r = await fetch(`${_BASE}${path}`, o); const t = await r.text(); let d; try { d = t ? JSON.parse(t) : {} } catch { throw new Error(t || `خطأ: ${r.status}`) } if (!r.ok) throw new Error(d.error || d.message || `خطأ: ${r.status}`); return d } catch (e) { if (path === '/auth/me') { const u = localStorage.getItem('sl_user'); if (u) return { user: JSON.parse(u) } } throw e } }
        const API = { auth: { async logout() { try { await _req('POST', '/auth/logout', {}) } catch { } localStorage.removeItem('sl_token'); localStorage.removeItem('sl_user'); window.location.href = 'login.html' }, async getSession() { const t = _getToken(); if (!t) return { valid: false }; try { const d = await _req('GET', '/auth/me'); return { valid: true, user: d.user, role: d.user.role } } catch { const u = localStorage.getItem('sl_user'); if (u) return { valid: true, user: JSON.parse(u), role: JSON.parse(u).role }; return { valid: false } } } } };

        // ── Auth Guard inline ──
        async function requireAuth() { const t = localStorage.getItem('sl_token'); if (!t) { window.location.href = 'login.html'; throw new Error('غير مسجّل') } const s = await API.auth.getSession(); if (!s.valid) { localStorage.removeItem('sl_token'); localStorage.removeItem('sl_user'); window.location.href = 'login.html'; throw new Error('انتهت الجلسة') } _injectUserUI(s.user); return s }
        async function logout() { await API.auth.logout() }
        function _injectUserUI(u) { if (!u) return; const sn = document.getElementById('sidebar-name'); if (sn) sn.textContent = u.name; const hn = document.getElementById('header-name'); if (hn) hn.textContent = `مرحباً، ${u.name}!`; const sr = document.getElementById('sidebar-role'); if (sr) sr.textContent = { doctor: 'دكتور', student: 'طالب' }[u.role] || u.role; const i = (u.name || 'U').charAt(0).toUpperCase(); const sa = document.getElementById('sidebar-avatar'); if (sa) { sa.textContent = i; sa.style.cssText += 'display:flex;align-items:center;justify-content:center;font-weight:700;font-size:1rem;background:var(--primary);color:white;' } const ha = document.getElementById('header-avatar'); if (ha) { ha.textContent = i; ha.style.cssText += 'display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.9rem;background:var(--primary);color:white;' } _applyRoleUI(u.role) }
        function _applyRoleUI(r) { document.querySelectorAll('.doctor-only').forEach(el => el.style.display = r === 'doctor' ? '' : 'none'); document.querySelectorAll('.admin-only').forEach(el => el.style.display = 'none'); document.querySelectorAll('.student-only').forEach(el => el.style.display = r === 'student' ? '' : 'none') }

        // ── Data inline ──
        const subjectsData = [
            { id: "programming-1", title: "برمجة الحاسوب 1", icon: "fa-code", description: "أساسيات البرمجة بلغة C++ والمفاهيم البرمجية الأساسية للهيكلة البرمجية.", theory: [{ id: "prog1-t1", title: "المحاضرة الأولى: مقدمة في البرمجة", pdfUrl: "../assets/pdfs/prog1_lec1.pdf", content: `<h3>مقدمة في البرمجة</h3><p>في هذه المحاضرة سنتعرف على تاريخ لغات البرمجة وكيفية عمل الحاسوب.</p><div style="background:#f1f5f9;padding:15px;border-radius:8px;margin:15px 0;"><strong>💡 ملاحظة هامة:</strong> البرمجة هي فن حل المشكلات باستخدام الآلة.</div><ul><li>ما هي لغة البرمجة؟</li><li>المجمع والمترجم (Compiler & Interpreter).</li><li>هيكلية برنامج C++.</li></ul>` }, { id: "prog1-t2", title: "المحاضرة الثانية: أنواع البيانات والمتغيرات", pdfUrl: "../assets/pdfs/prog1_lec2.pdf", content: `<h3>أنواع البيانات في C++</h3><p>شرح للـ int, float, double, char, string وكيفية تعريف المتغيرات.</p>` }], practical: [{ id: "prog1-p1", title: "التمرين الأول: بيئة العمل", pdfUrl: "../assets/pdfs/prog1_lab1.pdf", content: `<h3>إعداد بيئة التطوير</h3><p>خطوات تثبيت برامج التطوير مثل Code::Blocks أو Visual Studio وتشغيل أول برنامج "Hello World".</p>` }] },
            { id: "networks", title: "شبكات الحاسوب", icon: "fa-network-wired", description: "دراسة طبقات الشبكة وبروتوكولات الاتصال ونماذج OSI و TCP/IP.", theory: [{ id: "net-t1", title: "المحاضرة الأولى: مقدمة في الشبكات", pdfUrl: "../assets/pdfs/networks_lec1.pdf", content: `<p>مقدمة في طوبولوجيا الشبكات وأنواعها (LAN, WAN, MAN).</p>` }], practical: [{ id: "net-p1", title: "المخبر 1: كبسلة الكوابل", pdfUrl: "../assets/pdfs/networks_lab1.pdf", content: `<p>طريقة صنع كابل الشبكة (Straight & Crossover).</p>` }] },
            { id: "databases", title: "قواعد البيانات", icon: "fa-database", description: "مفاهيم قواعد البيانات العلائقية ولغة SQL وكيفية تصميم الجداول.", theory: [{ id: "db-t1", title: "المحاضرة 1: مقدمة في قواعد البيانات", pdfUrl: "../assets/pdfs/db_lec1.pdf", content: `<p>شرح مفهوم البيانات، المعلومات، ونظام إدارة قواعد البيانات (DBMS).</p>` }], practical: [{ id: "db-p1", title: "المخبر 1: لغة DDL", pdfUrl: "../assets/pdfs/db_lab1.pdf", content: `<p>استخدام أوامر CREATE, ALTER, DROP لتصميم الجداول.</p>` }] },
            { id: "ai", title: "الذكاء الاصطناعي", icon: "fa-brain", description: "خوارزميات البحث، المنطق، والتعلم الآلي والشبكات العصبية.", theory: [{ id: "ai-t1", title: "المحاضرة 1: ما هو الذكاء الاصطناعي؟", pdfUrl: "../assets/pdfs/ai_lec1.pdf", content: `<p>تاريخ الذكاء الاصطناعي واختبار تورينج والتطبيقات الحديثة.</p>` }], practical: [] }
        ];

        // ── UI Logic ──
        const LIVE_SYNC_KEY = 'enjaz_live_sync';
        const SIGNALR_URL = `http://${window.location.hostname}:5059/lectureHub`;
        let connection = null;

        const state = {
            currentSubject: null,
            currentType: 'theory',
            subjectSearchTerm: '',
            lectureSearchTerm: '',
            currentUser: null,
            canManage: false,
            isLive: false,
        };

        const subjectsGrid = document.getElementById('subjects-grid');
        const dashboardView = document.getElementById('dashboard-view');
        const lecturesView = document.getElementById('lectures-view');
        const detailsView = document.getElementById('details-view');
        const lecturesList = document.getElementById('lectures-list');
        const currentSubjectTitle = document.getElementById('current-subject-title');
        const currentLectureTitle = document.getElementById('current-lecture-title');
        const lectureBody = document.getElementById('lecture-body');
        const pdfLink = document.getElementById('pdf-link');
        const subjectSearch = document.getElementById('subject-search');
        const lectureSearch = document.getElementById('lecture-search');

        document.addEventListener('DOMContentLoaded', async () => {
            // ── تحديد العنصر النشط في القائمة حسب الصفحة الحالية ──
            const currentPage = window.location.pathname.split('/').pop() || 'Dashboard';
            document.querySelectorAll('.nav-item').forEach(item => {
                item.classList.remove('active');
                const href = item.getAttribute('href');
                const page = item.dataset.page;
                if (href === currentPage || page === currentPage.toLowerCase().replace('.html', '')) {
                    item.classList.add('active');
                }
            });

            // ── إضافة حدث النقر لتبديل العنصر النشط ──
            document.querySelectorAll('.nav-item').forEach(item => {
                item.addEventListener('click', function (e) {
                    // e.preventDefault(); // احذف هذا السطر إذا كنت تريد التنقل الفعلي
                    document.querySelectorAll('.nav-item').forEach(el => el.classList.remove('active'));
                    this.classList.add('active');
                });
            });

            try {
                const session = await requireAuth();
                state.currentUser = session.user;
                state.canManage = ['doctor', 'admin'].includes(session.role);
                mergeCustomData();
                const addLecBtn = document.getElementById('add-lecture-btn');
                const addSubBtn = document.getElementById('add-subject-btn');
                if (addLecBtn) addLecBtn.style.display = state.canManage ? 'inline-flex' : 'none';
                if (addSubBtn) addSubBtn.style.display = state.canManage ? 'inline-flex' : 'none';
                renderSubjects();
                bindEvents();
                setupLiveSync();
            } catch (err) { console.warn('Auth required:', err.message); }
        });

        function mergeCustomData() {
            const customList = JSON.parse(localStorage.getItem('enjaz_subjects_custom_list') || '[]');
            customList.forEach(s => { if (!subjectsData.find(ex => ex.id === s.id)) subjectsData.push(s); });
            const customDB = JSON.parse(localStorage.getItem('enjaz_subjects_custom') || '{}');
            subjectsData.forEach(subject => {
                if (customDB[subject.id]) {
                    ['theory', 'practical'].forEach(type => {
                        if (customDB[subject.id][type]) {
                            const existingIds = subject[type].map(l => l.id);
                            customDB[subject.id][type].forEach(l => { if (!existingIds.includes(l.id)) subject[type].push(l); });
                        }
                    });
                }
            });
        }

        function bindEvents() {
            document.getElementById('back-to-dashboard')?.addEventListener('click', () => showView('dashboard'));
            document.getElementById('back-to-lectures')?.addEventListener('click', () => showView('lectures'));
            document.getElementById('logout-btn')?.addEventListener('click', logout);
            subjectSearch?.addEventListener('input', e => { state.subjectSearchTerm = e.target.value.toLowerCase(); renderSubjects(); });
            lectureSearch?.addEventListener('input', e => { state.lectureSearchTerm = e.target.value.toLowerCase(); renderLectures(); });
            document.querySelectorAll('.tab').forEach(tab => {
                tab.addEventListener('click', e => {
                    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
                    e.currentTarget.classList.add('active');
                    state.currentType = e.currentTarget.dataset.type;
                    state.lectureSearchTerm = '';
                    if (lectureSearch) lectureSearch.value = '';
                    renderLectures();
                });
            });
            document.getElementById('add-lecture-btn')?.addEventListener('click', () => { if (state.canManage) openAddLectureModal(); });
            document.getElementById('add-subject-btn')?.addEventListener('click', () => { if (state.canManage) openAddSubjectModal(); });

            // ─── أحداث رفع الملفات المتطورة ───
            setupFileUploadEvents();

            document.getElementById('save-lecture-btn')?.addEventListener('click', saveLecture);
            document.getElementById('cancel-lecture-btn')?.addEventListener('click', closeAddLectureModal);
            document.getElementById('save-subject-btn')?.addEventListener('click', saveSubject);
            document.getElementById('cancel-subject-btn')?.addEventListener('click', closeAddSubjectModal);
            document.getElementById('mobile-toggle')?.addEventListener('click', () => {
                document.getElementById('sidebar').classList.toggle('open');
                document.querySelector('.sidebar-overlay')?.classList.toggle('active');
            });
            document.querySelector('.sidebar-overlay')?.addEventListener('click', () => {
                document.getElementById('sidebar').classList.remove('open');
                document.querySelector('.sidebar-overlay')?.classList.remove('active');
            });

            // زر رفع الملفات الإضافية
            document.getElementById('upload-additional-btn')?.addEventListener('click', uploadAdditionalFiles);
        }

        // ─── إعداد أحداث رفع الملفات ───
        function setupFileUploadEvents() {
            const dropZone = document.getElementById('file-drop-zone');
            const fileInput = document.getElementById('new-lec-file');
            const uploadedFilesList = document.getElementById('uploaded-files-list');

            if (dropZone && fileInput) {
                // النقر على المنطقة
                dropZone.addEventListener('click', () => fileInput.click());

                // اختيار الملف
                fileInput.addEventListener('change', (e) => {
                    if (e.target.files.length > 0) {
                        selectedModalFile = e.target.files[0];
                        displaySelectedFile(selectedModalFile, uploadedFilesList, 'modal');
                    }
                });

                // أحداث السحب والإفلات
                dropZone.addEventListener('dragover', (e) => {
                    e.preventDefault();
                    dropZone.classList.add('dragover');
                });

                dropZone.addEventListener('dragleave', () => {
                    dropZone.classList.remove('dragover');
                });

                dropZone.addEventListener('drop', (e) => {
                    e.preventDefault();
                    dropZone.classList.remove('dragover');
                    const files = e.dataTransfer.files;
                    if (files.length > 0) {
                        selectedModalFile = files[0];
                        fileInput.files = files;
                        displaySelectedFile(selectedModalFile, uploadedFilesList, 'modal');
                    }
                });
            }

            // ─── منطقة رفع الملفات الإضافية ───
            const additionalDropZone = document.getElementById('additional-file-drop-zone');
            const additionalFileInput = document.getElementById('additional-file-input');
            const additionalFilesList = document.getElementById('additional-files-list');

            if (additionalDropZone && additionalFileInput) {
                additionalDropZone.addEventListener('click', () => additionalFileInput.click());

                additionalFileInput.addEventListener('change', (e) => {
                    const files = Array.from(e.target.files);
                    selectedAdditionalFiles = [...selectedAdditionalFiles, ...files];
                    displayAdditionalFiles(additionalFilesList);
                });

                additionalDropZone.addEventListener('dragover', (e) => {
                    e.preventDefault();
                    additionalDropZone.classList.add('dragover');
                });

                additionalDropZone.addEventListener('dragleave', () => {
                    additionalDropZone.classList.remove('dragover');
                });

                additionalDropZone.addEventListener('drop', (e) => {
                    e.preventDefault();
                    additionalDropZone.classList.remove('dragover');
                    const files = Array.from(e.dataTransfer.files);
                    selectedAdditionalFiles = [...selectedAdditionalFiles, ...files];
                    displayAdditionalFiles(additionalFilesList);
                });
            }
        }

        // ─── عرض الملف المختار في المودال ───
        function displaySelectedFile(file, container, type) {
            const fileIcon = file.name.endsWith('.pdf') ? 'fa-file-pdf' :
                            file.name.match(/\.(jpg|jpeg|png)$/) ? 'fa-file-image' : 'fa-file';
            const fileSize = formatFileSize(file.size);

            container.innerHTML = `
                <div class="uploaded-file-item">
                    <i class="fas ${fileIcon}"></i>
                    <div class="uploaded-file-info">
                        <span>${file.name}</span>
                        <small>${fileSize}</small>
                    </div>
                    <button class="remove-file-btn" onclick="removeSelectedFile('${type}')" title="إزالة الملف">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
            `;
        }

        // ─── عرض الملفات الإضافية المختارة ───
        function displayAdditionalFiles(container) {
            if (selectedAdditionalFiles.length === 0) {
                container.innerHTML = '';
                document.getElementById('upload-additional-btn').style.display = 'none';
                return;
            }

            container.innerHTML = selectedAdditionalFiles.map((file, index) => {
                const fileIcon = file.name.endsWith('.pdf') ? 'fa-file-pdf' :
                                file.name.match(/\.(jpg|jpeg|png)$/) ? 'fa-file-image' : 'fa-file';
                const fileSize = formatFileSize(file.size);

                return `
                    <div class="uploaded-file-item">
                        <i class="fas ${fileIcon}"></i>
                        <div class="uploaded-file-info">
                            <span>${file.name}</span>
                            <small>${fileSize}</small>
                        </div>
                        <button class="remove-file-btn" onclick="removeAdditionalFile(${index})" title="إزالة الملف">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                `;
            }).join('');

            document.getElementById('upload-additional-btn').style.display = 'block';
        }

        // ─── إزالة الملف المختار ───
        window.removeSelectedFile = (type) => {
            if (type === 'modal') {
                selectedModalFile = null;
                document.getElementById('new-lec-file').value = '';
                document.getElementById('uploaded-files-list').innerHTML = '';
            }
        };

        // ─── إزالة ملف إضافي ───
        window.removeAdditionalFile = (index) => {
            selectedAdditionalFiles.splice(index, 1);
            displayAdditionalFiles(document.getElementById('additional-files-list'));
        };

        // ─── تنسيق حجم الملف ───
        function formatFileSize(bytes) {
            if (bytes === 0) return '0 Bytes';
            const k = 1024;
            const sizes = ['Bytes', 'KB', 'MB', 'GB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
        }

        function showView(view) {
            if (dashboardView) dashboardView.style.display = view === 'dashboard' ? 'block' : 'none';
            if (lecturesView) lecturesView.style.display = view === 'lectures' ? 'block' : 'none';
            if (detailsView) detailsView.style.display = view === 'details' ? 'block' : 'none';
        }

        function renderSubjects() {
            if (!subjectsGrid) return;
            const filtered = subjectsData.filter(s =>
                s.title.toLowerCase().includes(state.subjectSearchTerm) || s.description.toLowerCase().includes(state.subjectSearchTerm)
            );
            if (filtered.length === 0) { subjectsGrid.innerHTML = '<p style="padding:20px;color:var(--text-muted);grid-column:1/-1;text-align:center;">لا توجد مواد تطابق بحثك 🔍</p>'; return; }
            subjectsGrid.innerHTML = filtered.map(subject => `
                <div class="subject-card" onclick="openSubject('${subject.id}')" role="button" tabindex="0">
                    <div class="subject-icon"><i class="fas ${subject.icon}"></i></div>
                    <h3>${subject.title}</h3>
                    <p>${subject.description}</p>
                    <div class="subject-stats">
                        <span>📖 ${subject.theory?.length || 0} نظري</span>
                        <span>🔬 ${subject.practical?.length || 0} عملي</span>
                    </div>
                </div>
            `).join('');
        }

        window.openSubject = (id) => {
            const subject = subjectsData.find(s => s.id === id);
            if (!subject) return;
            state.currentSubject = subject;
            if (currentSubjectTitle) currentSubjectTitle.textContent = subject.title;
            state.lectureSearchTerm = '';
            if (lectureSearch) lectureSearch.value = '';
            const addBtn = document.getElementById('add-lecture-btn');
            if (addBtn) addBtn.style.display = state.canManage ? 'inline-flex' : 'none';
            renderLectures();
            showView('lectures');
        };

        function renderLectures() {
            if (!lecturesList || !state.currentSubject) return;
            const list = state.currentSubject[state.currentType] || [];
            const filtered = list.filter(l => l.title.toLowerCase().includes(state.lectureSearchTerm));
            if (filtered.length === 0) {
                lecturesList.innerHTML = `<div style="grid-column:1/-1;text-align:center;padding:40px;color:var(--text-muted);"><p style="font-size:2rem;margin-bottom:12px;">📭</p><p>${state.lectureSearchTerm ? 'لا توجد محاضرات تطابق بحثك' : 'لا توجد محاضرات بعد'}</p>${state.canManage ? '<p style="margin-top:8px;font-size:.85rem;">اضغط على "إضافة محاضرة" لإضافة محتوى جديد.</p>' : ''}</div>`;
                return;
            }
            lecturesList.innerHTML = filtered.map(lecture => `
                <div class="subject-card lecture-card" onclick="openLecture('${lecture.id}')" role="button" tabindex="0">
                    <div class="subject-icon" style="font-size:1.5rem;"><i class="fas fa-file-lines"></i></div>
                    <h3>${lecture.title}</h3>
                    <p>انقر لعرض المحتوى والشرح</p>
                    ${state.canManage ? `<button class="delete-lecture-btn" onclick="event.stopPropagation();deleteLecture('${lecture.id}')" title="حذف المحاضرة"><i class="fas fa-trash-alt"></i></button>` : ''}
                </div>
            `).join('');
        }

        window.openLecture = (id) => {
            if (!state.currentSubject) return;
            const lecture = state.currentSubject[state.currentType]?.find(l => l.id === id);
            if (!lecture) return;
            if (currentLectureTitle) currentLectureTitle.textContent = lecture.title;
            if (lectureBody) lectureBody.innerHTML = lecture.content || '<p style="color:var(--text-muted);text-align:center;padding:20px;">لا يوجد محتوى متوفر حالياً.</p>';
            if (pdfLink) {
                pdfLink.href = lecture.pdfUrl || '#';
                pdfLink.onclick = lecture.pdfUrl && lecture.pdfUrl !== '#' ? null : (e) => { e.preventDefault(); showToast('الملف غير متوفر حالياً 📁', 'info'); };
            }
            const togglePdfBtn = document.getElementById('toggle-pdf-btn');
            const pdfContainer = document.getElementById('pdf-viewer-container');
            const pdfIframe = document.getElementById('pdf-iframe');
            if (togglePdfBtn && pdfContainer && pdfIframe) {
                pdfContainer.style.display = 'none';
                pdfIframe.src = '';
                togglePdfBtn.innerHTML = '<i class="fas fa-file-pdf"></i> عرض الملف';
                if (lecture.pdfUrl && lecture.pdfUrl !== '#') {
                    togglePdfBtn.style.display = 'inline-flex';
                    togglePdfBtn.onclick = () => {
                        if (pdfContainer.style.display === 'none') { pdfIframe.src = lecture.pdfUrl; pdfContainer.style.display = 'block'; togglePdfBtn.innerHTML = '<i class="fas fa-eye-slash"></i> إخفاء الملف'; setTimeout(() => pdfContainer.scrollIntoView({ behavior: 'smooth', block: 'start' }), 100); }
                        else { pdfContainer.style.display = 'none'; pdfIframe.src = ''; togglePdfBtn.innerHTML = '<i class="fas fa-file-pdf"></i> عرض الملف'; }
                    };
                } else { togglePdfBtn.style.display = 'none'; }
            }
            showView('details');
            const broadcastBtn = document.getElementById('start-broadcast-btn');
            if (broadcastBtn) {
                if (state.currentUser?.role === 'doctor' || state.currentUser?.role === 'admin') {
                    broadcastBtn.style.display = 'inline-flex';
                    broadcastBtn.innerHTML = '<i class="fas fa-satellite-dish"></i> بدء بث مباشر للطلاب';
                    broadcastBtn.style.backgroundColor = '#e74c3c';
                    broadcastBtn.onclick = () => {
                        if (connection && (connection.state === signalR?.HubConnectionState?.Connected || connection.state === 'Connected')) {
                            broadcastLecture(state.currentSubject.id, id, state.currentType);
                            showToast('تم إرسال تنبيه البث للجميع 📡', 'success');
                            broadcastBtn.innerHTML = '<i class="fas fa-satellite-dish"></i> بث مباشر جاري 🔴';
                            broadcastBtn.style.backgroundColor = '#27ae60';
                        } else { showToast('أنت غير متصل بخادم البث', 'error'); }
                    };
                } else { broadcastBtn.style.display = 'none'; }
            }

            // ─── عرض الملفات المرفقة ───
            renderLectureFiles(lecture);

            // ─── إظهار/إخفاء قسم رفع الملفات الإضافية للدكاترة ───
            const uploadAdditionalSection = document.getElementById('upload-additional-section');
            if (uploadAdditionalSection) {
                if (state.canManage) {
                    uploadAdditionalSection.style.display = 'block';
                } else {
                    uploadAdditionalSection.style.display = 'none';
                }
            }

            // إعادة تعيين الملفات الإضافية المختارة
            selectedAdditionalFiles = [];
            document.getElementById('additional-files-list').innerHTML = '';
            document.getElementById('upload-additional-btn').style.display = 'none';
        };

        function broadcastLecture(subjectId, lectureId, type) {
            const doctorName = state.currentUser?.name || 'الدكتور';
            const lecture = state.currentSubject[type]?.find(l => l.id === lectureId);
            const syncData = { subjectId, lectureId, type, doctorName, lectureTitle: lecture?.title || 'محاضرة', pdfUrl: lecture?.pdfUrl || '#', timestamp: Date.now() };
            localStorage.setItem(LIVE_SYNC_KEY, JSON.stringify(syncData));
            if (connection && String(connection.state) === 'Connected') {
                connection.invoke('BroadcastLectureStart', String(subjectId), String(lectureId), String(type), String(doctorName), String(syncData.lectureTitle), String(syncData.pdfUrl)).catch(err => console.error('SignalR Broadcast Error:', err));
            }
        }

        function setupLiveSync() {
            if (window.signalR) {
                connection = new signalR.HubConnectionBuilder().withUrl(SIGNALR_URL).withAutomaticReconnect().build();
                connection.on('ReceiveLectureStart', (subjectId, lectureId, type, doctorName, lectureTitle, pdfUrl) => {
                    handleIncomingSync({ subjectId, lectureId, type, doctorName, lectureTitle, pdfUrl, timestamp: Date.now() });
                });
                async function startSignalR() { try { await connection.start(); } catch { setTimeout(startSignalR, 5000); } }
                startSignalR();
            }
            window.addEventListener('storage', e => { if (e.key === LIVE_SYNC_KEY && e.newValue) handleIncomingSync(JSON.parse(e.newValue)); });
            const currentSync = JSON.parse(localStorage.getItem(LIVE_SYNC_KEY));
            if (currentSync && (Date.now() - currentSync.timestamp < 120000)) showLiveIndicator(currentSync);
        }

        function handleIncomingSync(data) {
            showToast(`🔴 بث مباشر: ${data.doctorName} بدأ بشرح محاضرة الآن`, 'success');
            showLiveIndicator(data);
            setTimeout(() => { if (confirm(`الدكتور يشرح الآن: "${data.lectureTitle}". هل تريد الانضمام؟`)) syncToLectureByIds(data.subjectId, data.lectureId, data.type, data.lectureTitle, data.pdfUrl); }, 1500);
        }

        function showLiveIndicator(data) {
            const headerRight = document.querySelector('.header-right');
            if (!headerRight) return;
            document.getElementById('live-indicator')?.remove();
            const indicator = document.createElement('div');
            indicator.id = 'live-indicator';
            indicator.className = 'live-badge-pulse';
            indicator.innerHTML = `<span class="pulse-dot"></span><span onclick="syncToLectureByIds('${data.subjectId}','${data.lectureId}','${data.type}')">بث مباشر: ${data.doctorName}</span>`;
            headerRight.prepend(indicator);
        }

        window.syncToLectureByIds = (subjectId, lectureId, type, lectureTitle, pdfUrl) => {
            let sub = subjectsData.find(s => s.id === subjectId);
            if (!sub) { sub = { id: subjectId, title: 'مادة البث المباشر', icon: 'fa-satellite-dish', description: 'مادة يتم شرحها الآن', theory: [], practical: [] }; subjectsData.push(sub); renderSubjects(); }
            if (!sub[type]) sub[type] = [];
            let lec = sub[type].find(l => l.id === lectureId);
            if (!lec) { lec = { id: lectureId, title: lectureTitle || 'محاضرة البث', pdfUrl: pdfUrl || '#', content: '<p>يتم جلب المحتوى...</p>' }; sub[type].push(lec); }
            window.openSubject(subjectId);
            state.currentType = type;
            document.querySelectorAll('.tab').forEach(t => t.classList.toggle('active', t.dataset.type === type));
            window.openLecture(lectureId);
            showToast('تمت المزامنة مع شرح الدكتور ✨', 'success');
        };

        function openAddLectureModal() {
            const modal = document.getElementById('add-lecture-modal');
            if (!modal) return;
            document.getElementById('new-lec-title').value = '';
            document.getElementById('new-lec-url').value = '';
            document.getElementById('new-lec-file').value = '';
            document.getElementById('new-lec-content').value = '';
            document.getElementById('uploaded-files-list').innerHTML = '';
            selectedModalFile = null;
            modal.style.display = 'flex';
        }
        function closeAddLectureModal() { const m = document.getElementById('add-lecture-modal'); if (m) m.style.display = 'none'; }

        function saveLecture() {
            if (!state.canManage || !state.currentSubject) return;
            const title = document.getElementById('new-lec-title')?.value.trim();
            let pdfUrl = document.getElementById('new-lec-url')?.value.trim();
            const content = document.getElementById('new-lec-content')?.value.trim();
            const fileInput = document.getElementById('new-lec-file');
            if (!title) { showToast('أدخل عنوان المحاضرة', 'error'); return; }
            if (fileInput && fileInput.files.length > 0) {
                const reader = new FileReader();
                reader.onload = e => _finalizeLectureSave(title, e.target.result, content);
                reader.onerror = () => _finalizeLectureSave(title, pdfUrl, content);
                reader.readAsDataURL(fileInput.files[0]);
            } else { _finalizeLectureSave(title, pdfUrl, content); }
        }

        function _finalizeLectureSave(title, pdfUrl, content) {
            const newLecture = { id: `lec_${Date.now()}`, title, pdfUrl: pdfUrl || '#', content: content ? `<p>${content}</p>` : '<p>لا يوجد محتوى بعد.</p>', addedAt: new Date().toISOString() };
            if (!state.currentSubject[state.currentType]) state.currentSubject[state.currentType] = [];
            state.currentSubject[state.currentType].push(newLecture);
            const key = 'enjaz_subjects_custom';
            const customDB = JSON.parse(localStorage.getItem(key) || '{}');
            customDB[state.currentSubject.id] = customDB[state.currentSubject.id] || {};
            customDB[state.currentSubject.id][state.currentType] = state.currentSubject[state.currentType];
            localStorage.setItem(key, JSON.stringify(customDB));
            closeAddLectureModal();
            renderLectures();
            showToast(`تمت إضافة "${title}" بنجاح 📚`, 'success');
        }

        function openAddSubjectModal() {
            const modal = document.getElementById('add-subject-modal');
            if (!modal) return;
            document.getElementById('new-sub-title').value = '';
            document.getElementById('new-sub-desc').value = '';
            modal.style.display = 'flex';
        }
        function closeAddSubjectModal() { const m = document.getElementById('add-subject-modal'); if (m) m.style.display = 'none'; }

        function saveSubject() {
            if (!state.canManage) return;
            const title = document.getElementById('new-sub-title')?.value.trim();
            const desc = document.getElementById('new-sub-desc')?.value.trim();
            const icon = document.getElementById('new-sub-icon')?.value || 'fa-book';
            if (!title) { showToast('أدخل اسم المادة', 'error'); return; }
            const newSubject = { id: `sub_${Date.now()}`, title, icon, description: desc || 'لا يوجد وصف حالياً.', theory: [], practical: [] };
            subjectsData.push(newSubject);
            const key = 'enjaz_subjects_custom_list';
            const customList = JSON.parse(localStorage.getItem(key) || '[]');
            customList.push(newSubject);
            localStorage.setItem(key, JSON.stringify(customList));
            closeAddSubjectModal();
            renderSubjects();
            showToast(`تم إنشاء مادة "${title}" بنجاح 📂`, 'success');
        }

        window.deleteLecture = (id) => {
            if (!state.canManage || !state.currentSubject) return;
            if (!confirm('هل تريد حذف هذه المحاضرة؟')) return;
            state.currentSubject[state.currentType] = state.currentSubject[state.currentType].filter(l => l.id !== id);
            const key = 'enjaz_subjects_custom';
            const customDB = JSON.parse(localStorage.getItem(key) || '{}');
            if (customDB[state.currentSubject.id]) { customDB[state.currentSubject.id][state.currentType] = state.currentSubject[state.currentType]; localStorage.setItem(key, JSON.stringify(customDB)); }
            renderLectures();
            showToast('تم حذف المحاضرة', 'info');
        };

        function showToast(msg, type) {
            const toast = document.getElementById('toast');
            if (!toast) return;
            toast.textContent = msg;
            toast.className = 'toast ' + (type || 'info') + ' show';
            setTimeout(function() { toast.classList.remove('show'); }, 3000);
        }

        function renderLectureFiles(lecture) {
            const filesList = document.getElementById('lecture-files-list');
            if (!filesList) return;
            var files = [];
            if (lecture.pdfUrl && lecture.pdfUrl !== '#') {
                var isDataUrl = lecture.pdfUrl.indexOf('data:') === 0;
                var fileName = isDataUrl ? 'ملف المحاضرة.pdf' : decodeURIComponent(lecture.pdfUrl.split('/').pop());
                files.push({ name: fileName, url: lecture.pdfUrl, type: fileName.indexOf('.pdf') > -1 ? 'pdf' : 'image', isMain: true });
            }
            if (lecture.additionalFiles && lecture.additionalFiles.length > 0) {
                lecture.additionalFiles.forEach(function(file, index) {
                    files.push({ name: file.name, url: file.url, type: file.name.indexOf('.pdf') > -1 ? 'pdf' : 'image', isMain: false, index: index });
                });
            }
            if (files.length === 0) {
                filesList.innerHTML = '<p style="text-align: center; color: var(--text-muted); padding: 20px;">لا توجد ملفات مرفقة 📭</p>';
                return;
            }
            filesList.innerHTML = files.map(function(file) {
                var fileIcon = file.type === 'pdf' ? 'fa-file-pdf' : 'fa-file-image';
                var mainBadge = file.isMain ? '<span style="background: var(--primary); color: white; padding: 2px 8px; border-radius: 10px; font-size: 0.7rem; margin-left: 8px;">رئيسي</span>' : '';
                // Allow delete for all files if user can manage
                var deleteBtn = state.canManage ? '<button class="file-action-btn delete" onclick="' + (file.isMain ? 'deleteMainFile()' : 'deleteLectureFile(' + file.index + ')') + '" title="حذف الملف"><i class="fas fa-trash"></i></button>' : '';
                var viewBtn = '<button class="file-action-btn view" onclick="viewFileInPlayer(\'' + encodeURIComponent(file.url) + '\')" title="عرض الملف"><i class="fas fa-eye"></i> عرض</button>';
                return '<div class="file-item"><i class="fas ' + fileIcon + '"></i><div class="file-item-details"><span>' + file.name + mainBadge + '</span><small>' + (file.type === 'pdf' ? 'مستند PDF' : 'صورة') + '</small></div><div class="file-item-actions">' + viewBtn + '<button class="file-action-btn download" onclick="downloadFile(\'' + encodeURIComponent(file.url) + '\', \'' + file.name + '\')" title="تحميل الملف"><i class="fas fa-download"></i> تحميل</button>' + deleteBtn + '</div></div>';
            }).join('');
        }

        window.viewFileInPlayer = function(encodedUrl) {
            var url = decodeURIComponent(encodedUrl);
            var pdfContainer = document.getElementById('pdf-viewer-container');
            var pdfIframe = document.getElementById('pdf-iframe');
            var togglePdfBtn = document.getElementById('toggle-pdf-btn');

            if (pdfIframe && pdfContainer) {
                pdfIframe.src = url;
                pdfContainer.style.display = 'block';
                if (togglePdfBtn) {
                    togglePdfBtn.innerHTML = '<i class="fas fa-eye-slash"></i> إخفاء الملف';
                }
                // Scroll to viewer
                setTimeout(function() {
                    pdfContainer.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }, 100);
            }
        };

        window.downloadFile = function(encodedUrl, fileName) {
            var url = decodeURIComponent(encodedUrl);
            // Data URL (base64)
            if (url.indexOf('data:') === 0) {
                var link = document.createElement('a');
                link.href = url;
                link.download = fileName;
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
            } else {
                // External URL - open in new tab
                window.open(url, '_blank');
            }
        };

        window.deleteLectureFile = function(index) {
            if (!state.canManage) return;
            if (!confirm('هل تريد حذف هذا الملف؟')) return;
            var lectureTitle = document.getElementById('current-lecture-title').textContent;
            var lecture = state.currentSubject[state.currentType]?.find(function(l) { return l.title === lectureTitle; });
            if (!lecture || !lecture.additionalFiles) return;
            lecture.additionalFiles.splice(index, 1);
            var key = 'enjaz_subjects_custom';
            var customDB = JSON.parse(localStorage.getItem(key) || '{}');
            customDB[state.currentSubject.id] = customDB[state.currentSubject.id] || {};
            customDB[state.currentSubject.id][state.currentType] = state.currentSubject[state.currentType];
            localStorage.setItem(key, JSON.stringify(customDB));
            renderLectureFiles(lecture);
            showToast('تم حذف الملف', 'info');
        };

        window.deleteMainFile = function() {
            if (!state.canManage) return;
            if (!confirm('هل تريد حذف الملف الرئيسي للمحاضرة؟')) return;
            var lectureTitle = document.getElementById('current-lecture-title').textContent;
            var lecture = state.currentSubject[state.currentType]?.find(function(l) { return l.title === lectureTitle; });
            if (!lecture) return;
            lecture.pdfUrl = '#';
            var key = 'enjaz_subjects_custom';
            var customDB = JSON.parse(localStorage.getItem(key) || '{}');
            customDB[state.currentSubject.id] = customDB[state.currentSubject.id] || {};
            customDB[state.currentSubject.id][state.currentType] = state.currentSubject[state.currentType];
            localStorage.setItem(key, JSON.stringify(customDB));
            renderLectureFiles(lecture);
            showToast('تم حذف الملف الرئيسي', 'info');
        };

        async function uploadAdditionalFiles() {
            if (!state.canManage || selectedAdditionalFiles.length === 0) return;
            var uploadBtn = document.getElementById('upload-additional-btn');
            var originalText = uploadBtn.innerHTML;
            uploadBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري الرفع...';
            uploadBtn.disabled = true;
            var lectureTitle = document.getElementById('current-lecture-title').textContent;
            var lecture = state.currentSubject[state.currentType]?.find(function(l) { return l.title === lectureTitle; });
            if (!lecture) { uploadBtn.innerHTML = originalText; uploadBtn.disabled = false; return; }
            var newFiles = [];
            for (var i = 0; i < selectedAdditionalFiles.length; i++) {
                try {
                    var dataUrl = await readFileAsDataURL(selectedAdditionalFiles[i]);
                    newFiles.push({ name: selectedAdditionalFiles[i].name, url: dataUrl, size: selectedAdditionalFiles[i].size, addedAt: new Date().toISOString() });
                } catch (err) { console.error('Error reading file:', err); }
            }
            if (!lecture.additionalFiles) lecture.additionalFiles = [];
            lecture.additionalFiles.push.apply(lecture.additionalFiles, newFiles);
            var key = 'enjaz_subjects_custom';
            var customDB = JSON.parse(localStorage.getItem(key) || '{}');
            customDB[state.currentSubject.id] = customDB[state.currentSubject.id] || {};
            customDB[state.currentSubject.id][state.currentType] = state.currentSubject[state.currentType];
            localStorage.setItem(key, JSON.stringify(customDB));
            selectedAdditionalFiles = [];
            document.getElementById('additional-files-list').innerHTML = '';
            uploadBtn.style.display = 'none';
            uploadBtn.innerHTML = originalText;
            uploadBtn.disabled = false;
            renderLectureFiles(lecture);
            showToast('تم رفع ' + newFiles.length + ' ملف/ملفات بنجاح 📎', 'success');
        }

        function readFileAsDataURL(file) {
            return new Promise(function(resolve, reject) {
                var reader = new FileReader();
                reader.onload = function() { resolve(reader.result); };
                reader.onerror = reject;
                reader.readAsDataURL(file);
            });
        }
    </script>
</body>

</html>
