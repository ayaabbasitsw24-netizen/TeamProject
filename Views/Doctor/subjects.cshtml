<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>المواد الدراسية — عشاق الدراسة</title>
    <meta name="description" content="تصفح المواد الدراسية والمحاضرات">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&display=swap" rel="stylesheet">
    <style>
        /* ── Design System (مدمج) ── */
        .theme-blue {
            --primary: #4e7bef;
            --primary-light: #7ea8f5;
            --primary-dark: #2d57cc;
            --accent-bg: rgba(78, 123, 239, 0.07);
            --sidebar-bg: #f7f9ff;
            --sidebar-text: #354060;
            --bg: #f0f4fb;
            --card-bg: #ffffff;
            --text-main: #1a2540;
            --text-muted: #6c7a95;
            --border: #e3e8f4;
            --shadow-sm: 0 2px 8px rgba(78, 123, 239, .08);
            --shadow-md: 0 6px 24px rgba(78, 123, 239, .13);
            --shadow-lg: 0 12px 45px rgba(78, 123, 239, .18);
        }

        .theme-purple {
            --primary: #7c50e0;
            --primary-light: #a484ee;
            --primary-dark: #5630b5;
            --accent-bg: rgba(124, 80, 224, 0.07);
            --sidebar-bg: #f8f5ff;
            --sidebar-text: #3a2060;
            --bg: #f3f0fd;
            --card-bg: #ffffff;
            --text-main: #220e45;
            --text-muted: #7060a0;
            --border: #e4d8f8;
            --shadow-sm: 0 2px 8px rgba(124, 80, 224, .08);
            --shadow-md: 0 6px 24px rgba(124, 80, 224, .13);
            --shadow-lg: 0 12px 45px rgba(124, 80, 224, .18);
        }

        .theme-green {
            --primary: #1db27a;
            --primary-light: #4fcda0;
            --primary-dark: #128a5e;
            --accent-bg: rgba(29, 178, 122, 0.07);
            --sidebar-bg: #f3fbf7;
            --sidebar-text: #1a3d2e;
            --bg: #eef9f4;
            --card-bg: #ffffff;
            --text-main: #0d2e20;
            --text-muted: #5a8070;
            --border: #c8eedc;
            --shadow-sm: 0 2px 8px rgba(29, 178, 122, .08);
            --shadow-md: 0 6px 24px rgba(29, 178, 122, .13);
            --shadow-lg: 0 12px 45px rgba(29, 178, 122, .18);
        }

        .theme-dark {
            --primary: #8b7cf8;
            --primary-light: #a89ef9;
            --primary-dark: #6a5cd4;
            --accent-bg: rgba(139, 124, 248, .12);
            --sidebar-bg: #1b1b30;
            --sidebar-text: #c4c4e0;
            --bg: #111120;
            --card-bg: #1e1e35;
            --text-main: #e6e6fa;
            --text-muted: #8080aa;
            --border: rgba(255, 255, 255, .08);
            --shadow-sm: 0 2px 8px rgba(0, 0, 0, .3);
            --shadow-md: 0 6px 24px rgba(0, 0, 0, .4);
            --shadow-lg: 0 12px 45px rgba(0, 0, 0, .55);
        }

        *,
        *::before,
        *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box
        }

        body {
            font-family: 'Tajawal', sans-serif;
            background: var(--bg);
            color: var(--text-main);
            min-height: 100vh;
            direction: rtl;
            transition: background .35s, color .35s
        }

        a {
            text-decoration: none;
            color: inherit
        }

        .app-wrapper {
            display: flex;
            min-height: 100vh
        }

        .sidebar {
            width: 260px;
            background: var(--sidebar-bg);
            border-left: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            position: fixed;
            right: 0;
            top: 0;
            height: 100vh;
            z-index: 200;
            transition: transform .3s cubic-bezier(.4, 0, .2, 1), box-shadow .3s;
            box-shadow: -2px 0 16px rgba(0, 0, 0, .06);
            overflow-y: auto
        }

        .sidebar-header {
            padding: 22px 18px 16px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 10px
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 10px
        }

        .logo-icon {
            font-size: 1.6rem
        }

        .logo-text {
            font-size: 1.15rem;
            font-weight: 700;
            color: var(--primary);
            letter-spacing: -.3px
        }

        .sidebar-nav {
            flex: 1;
            padding: 12px 10px
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            border-radius: 12px;
            margin-bottom: 4px;
            color: var(--sidebar-text);
            font-size: .95rem;
            font-weight: 500;
            cursor: pointer;
            transition: all .2s
        }

            .nav-item i {
                width: 20px;
                text-align: center;
                font-size: 1rem;
                opacity: .7;
                transition: opacity .2s
            }

            .nav-item:hover {
                background: var(--accent-bg);
                color: var(--primary)
            }

            .nav-item.active {
                background: linear-gradient(135deg, var(--primary), var(--primary-dark));
                color: #fff;
                font-weight: 600;
                box-shadow: 0 4px 14px rgba(0, 0, 0, .2);
            }

                .nav-item.active i {
                    opacity: 1;
                    color: #fff
                }

        .sidebar-footer {
            padding: 14px 16px;
            border-top: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 10px
        }

        .user-mini {
            flex: 1;
            display: flex;
            align-items: center;
            gap: 10px;
            overflow: hidden
        }

        .user-mini-avatar {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            background: var(--accent-bg);
            border: 2px solid var(--primary-light);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            flex-shrink: 0;
            overflow: hidden
        }

        .user-mini-info {
            overflow: hidden
        }

            .user-mini-info span {
                font-size: .85rem;
                font-weight: 600;
                display: block;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis
            }

            .user-mini-info small {
                font-size: .73rem;
                color: var(--text-muted)
            }

        .logout-btn {
            background: none;
            border: none;
            cursor: pointer;
            color: var(--text-muted);
            font-size: 1rem;
            padding: 6px 8px;
            border-radius: 8px;
            transition: all .2s
        }

            .logout-btn:hover {
                background: #fee2e2;
                color: #ef4444
            }

        .main-wrapper {
            margin-right: 260px;
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 100vh
        }

        .top-header {
            background: var(--card-bg);
            border-bottom: 1px solid var(--border);
            padding: 14px 28px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: var(--shadow-sm)
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 14px
        }

        .page-title {
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--text-main)
        }

        .mobile-toggle {
            display: none;
            background: none;
            border: none;
            cursor: pointer;
            font-size: 1.2rem;
            color: var(--text-muted);
            padding: 4px 6px;
            border-radius: 8px
        }

        .header-right {
            display: flex;
            align-items: center;
            gap: 14px
        }

        .header-user {
            display: flex;
            align-items: center;
            gap: 10px
        }

            .header-user span {
                font-size: .9rem;
                color: var(--text-muted)
            }

        .header-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: var(--accent-bg);
            border: 2px solid var(--primary-light);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            overflow: hidden
        }

        .content-area {
            flex: 1;
            padding: 20px 24px;
            overflow-y: auto
        }

        .page-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 24px;
            flex-wrap: wrap;
            gap: 12px
        }

            .page-header h2 {
                font-size: 1.45rem;
                font-weight: 700;
                display: flex;
                align-items: center;
                gap: 8px
            }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: #fff;
            border: none;
            padding: 10px 22px;
            border-radius: 12px;
            font-family: inherit;
            font-size: .95rem;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            box-shadow: 0 4px 14px rgba(0, 0, 0, .15);
            transition: all .25s
        }

            .btn-primary:hover {
                transform: translateY(-2px);
                filter: brightness(1.1);
                box-shadow: 0 8px 22px rgba(0, 0, 0, .22)
            }

        .btn-secondary {
            background: var(--card-bg);
            color: var(--text-muted);
            border: 1px solid var(--border);
            padding: 10px 20px;
            border-radius: 12px;
            font-family: inherit;
            font-size: .9rem;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all .2s
        }

            .btn-secondary:hover {
                background: var(--accent-bg);
                color: var(--primary);
                border-color: var(--primary-light)
            }

        .subjects-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 18px
        }

        .subject-card {
            background: var(--card-bg);
            border-radius: 20px;
            padding: 28px 20px;
            border: 1px solid var(--border);
            box-shadow: var(--shadow-sm);
            text-align: center;
            cursor: pointer;
            position: relative;
            overflow: hidden;
            transition: all .35s cubic-bezier(.175, .885, .32, 1.275)
        }

            .subject-card::before {
                content: '';
                position: absolute;
                top: 0;
                right: 0;
                left: 0;
                height: 4px;
                background: linear-gradient(to left, var(--primary), var(--primary-light))
            }

            .subject-card:hover {
                transform: translateY(-8px) scale(1.03);
                box-shadow: var(--shadow-lg)
            }

        .subject-icon {
            font-size: 2.5rem;
            margin-bottom: 12px;
            color: var(--primary);
            position: relative;
            z-index: 1
        }

        .subject-card h3 {
            font-size: 1rem;
            font-weight: 700;
            margin-bottom: 6px;
            position: relative;
            z-index: 1
        }

        .subject-card p {
            font-size: .82rem;
            color: var(--text-muted);
            line-height: 1.5;
            position: relative;
            z-index: 1
        }

        .tabs {
            display: flex;
            gap: 8px;
            margin-bottom: 20px;
            flex-wrap: wrap
        }

        .tab {
            padding: 9px 22px;
            border-radius: 20px;
            background: var(--card-bg);
            border: 1px solid var(--border);
            font-family: inherit;
            font-size: .9rem;
            color: var(--text-muted);
            cursor: pointer;
            transition: all .2s
        }

            .tab.active {
                background: var(--primary);
                border-color: var(--primary);
                color: #fff
            }

            .tab:not(.active):hover {
                border-color: var(--primary-light);
                color: var(--primary)
            }

        .lecture-card {
            background: var(--card-bg);
            border-radius: 16px;
            padding: 18px 20px;
            border: 1px solid var(--border);
            box-shadow: var(--shadow-sm);
            cursor: pointer;
            transition: all .25s;
            position: relative
        }

            .lecture-card:hover {
                transform: translateY(-3px);
                box-shadow: var(--shadow-md)
            }

        .delete-lecture-btn {
            position: absolute;
            top: 10px;
            left: 10px;
            background: rgba(239, 68, 68, .1);
            border: none;
            color: #ef4444;
            width: 30px;
            height: 30px;
            border-radius: 8px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .8rem;
            opacity: 0;
            transition: all .2s
        }

        .lecture-card:hover .delete-lecture-btn {
            opacity: 1
        }

        .delete-lecture-btn:hover {
            background: #ef4444;
            color: #fff
        }

        .subject-stats {
            display: flex;
            gap: 10px;
            margin-top: 10px;
            font-size: .78rem;
            color: var(--text-muted)
        }

            .subject-stats span {
                background: var(--accent-bg);
                padding: 3px 10px;
                border-radius: 20px
            }

        /* ─── قسم الملفات المرفقة ─── */
        .lecture-files-section {
            background: var(--card-bg);
            border-radius: 18px;
            padding: 24px;
            border: 1px solid var(--border);
            margin-bottom: 20px
        }

            .lecture-files-section h3 {
                margin: 0 0 16px 0;
                font-size: 1.1rem;
                color: var(--text-main);
                display: flex;
                align-items: center;
                gap: 8px
            }

        .file-list {
            display: flex;
            flex-direction: column;
            gap: 10px
        }

        .file-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 14px 16px;
            background: var(--bg);
            border-radius: 12px;
            border: 1px solid var(--border);
            transition: all 0.2s
        }

            .file-item:hover {
                border-color: var(--primary);
                transform: translateX(-4px)
            }

            .file-item i {
                font-size: 1.5rem;
                color: var(--primary)
            }

        .file-item-details {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 4px
        }

            .file-item-details span {
                font-weight: 600;
                color: var(--text-main);
                font-size: 0.95rem
            }

            .file-item-details small {
                color: var(--text-muted);
                font-size: 0.8rem
            }

        .file-item-actions {
            display: flex;
            gap: 8px
        }

        .file-action-btn {
            padding: 8px 14px;
            border-radius: 8px;
            border: none;
            cursor: pointer;
            font-size: 0.85rem;
            display: flex;
            align-items: center;
            gap: 6px;
            transition: all 0.2s
        }

            .file-action-btn.download {
                background: var(--primary);
                color: white
            }

                .file-action-btn.download:hover {
                    opacity: 0.9
                }

            .file-action-btn.delete {
                background: rgba(239, 68, 68, 0.1);
                color: #ef4444
            }

                .file-action-btn.delete:hover {
                    background: #ef4444;
                    color: white
                }

            .file-action-btn.view {
                background: rgba(16, 185, 129, 0.1);
                color: #10b981
            }

                .file-action-btn.view:hover {
                    background: #10b981;
                    color: white
                }

        /* ─── منطقة رفع الملفات ─── */
        .file-upload-area {
            border: 2px dashed var(--border);
            border-radius: 16px;
            padding: 32px 24px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
            background: var(--bg)
        }

            .file-upload-area:hover {
                border-color: var(--primary);
                background: rgba(67, 97, 238, 0.05)
            }

            .file-upload-area.dragover {
                border-color: var(--primary);
                background: rgba(67, 97, 238, 0.1);
                transform: scale(1.02)
            }

            .file-upload-area i {
                font-size: 2.5rem;
                color: var(--primary);
                margin-bottom: 12px
            }

            .file-upload-area h4 {
                margin: 0 0 8px 0;
                color: var(--text-main);
                font-size: 1rem
            }

            .file-upload-area p {
                margin: 0;
                color: var(--text-muted);
                font-size: 0.85rem
            }

        /* ─── الملف المختار ─── */
        .uploaded-file-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            background: var(--bg);
            border-radius: 10px;
            border: 1px solid var(--border);
            margin-bottom: 8px
        }

            .uploaded-file-item i {
                font-size: 1.3rem;
                color: var(--primary)
            }

        .uploaded-file-info {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 2px
        }

            .uploaded-file-info span {
                font-weight: 600;
                color: var(--text-main);
                font-size: 0.9rem
            }

            .uploaded-file-info small {
                color: var(--text-muted);
                font-size: 0.75rem
            }

        .remove-file-btn {
            width: 28px;
            height: 28px;
            border-radius: 6px;
            border: none;
            background: rgba(239, 68, 68, 0.1);
            color: #ef4444;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s
        }

            .remove-file-btn:hover {
                background: #ef4444;
                color: white
            }

        .toast {
            position: fixed;
            bottom: 28px;
            left: 50%;
            transform: translateX(-50%) translateY(120px);
            background: #1e293b;
            color: #fff;
            padding: 12px 26px;
            border-radius: 30px;
            font-size: .9rem;
            z-index: 9999;
            transition: transform .35s cubic-bezier(.175, .885, .32, 1.275);
            white-space: nowrap;
            pointer-events: none;
            box-shadow: 0 8px 30px rgba(0, 0, 0, .2)
        }

            .toast.show {
                transform: translateX(-50%) translateY(0)
            }

            .toast.success {
                background: #16a34a
            }

            .toast.error {
                background: #dc2626
            }

            .toast.info {
                background: var(--primary)
            }

        .sidebar-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, .45);
            z-index: 150;
            backdrop-filter: blur(3px)
        }

            .sidebar-overlay.active {
                display: block
            }

        .doctor-only {
            display: none
        }

        .live-badge-pulse {
            display: flex;
            align-items: center;
            gap: 8px;
            background: rgba(239, 68, 68, .1);
            color: #ef4444;
            padding: 6px 14px;
            border-radius: 20px;
            font-size: .8rem;
            font-weight: 700;
            border: 1px solid rgba(239, 68, 68, .2);
            cursor: pointer;
            transition: .3s;
            margin-left: 10px
        }

            .live-badge-pulse:hover {
                background: rgba(239, 68, 68, .2);
                transform: translateY(-1px)
            }

        .pulse-dot {
            width: 8px;
            height: 8px;
            background: #ef4444;
            border-radius: 50%;
            position: relative;
            display: inline-block
        }

            .pulse-dot::after {
                content: '';
                position: absolute;
                width: 100%;
                height: 100%;
                background: #ef4444;
                border-radius: 50%;
                animation: live-pulse 1.5s infinite;
                left: 0;
                top: 0
            }

        @@keyframes live-pulse {
            0%

        {
            transform: scale(1);
            opacity: 1;
        }

        100% {
            transform: scale(2.5);
            opacity: 0;
        }

        }

        .tool-card {
            background: var(--card-bg);
            border-radius: 18px;
            padding: 24px;
            border: 1px solid var(--border);
            box-shadow: var(--shadow-sm);
            transition: .3s
        }

            .tool-card:hover {
                box-shadow: var(--shadow-md);
                transform: translateY(-2px)
            }

            .tool-card h3 {
                font-size: 1.1rem;
                margin-bottom: 12px;
                color: var(--primary);
                display: flex;
                align-items: center;
                gap: 10px
            }

            .tool-card p {
                font-size: .85rem;
                color: var(--text-muted);
                margin-bottom: 15px;
                line-height: 1.5
            }

        .timer-display {
            font-size: 3rem;
            font-weight: 800;
            text-align: center;
            margin: 15px 0;
            font-family: monospace;
            color: var(--text-main);
            background: var(--bg);
            padding: 10px;
            border-radius: 12px;
            letter-spacing: 4px
        }

        .modal-box {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 28px;
            width: 460px;
            max-width: 95vw;
            animation: slideUp .25s ease
        }

        @@keyframes slideUp {
            from

        {
            transform: translateY(30px);
            opacity: 0;
        }

        to {
            transform: translateY(0);
            opacity: 1;
        }

        }

        @@keyframes fadeIn {
            from

        {
            opacity: 0;
            transform: translateY(12px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }

        @@keyframes modalIn {
            from

        {
            opacity: 0;
            transform: scale(0.95);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }

        }

        /* ── تنسيقات البحث ── */
        .search-container {
            position: relative;
            display: inline-flex;
            align-items: center;
        }

            .search-container input {
                padding: 10px 40px 10px 16px;
                border: 1.5px solid var(--border);
                border-radius: 12px;
                background: var(--bg);
                color: var(--text-main);
                font-family: inherit;
                font-size: 0.9rem;
                width: 220px;
                transition: all 0.2s;
            }

                .search-container input:focus {
                    outline: none;
                    border-color: var(--primary);
                    box-shadow: 0 0 0 3px var(--accent-bg);
                }

            .search-container .search-icon {
                position: absolute;
                right: 14px;
                color: var(--text-muted);
                font-size: 0.9rem;
                pointer-events: none;
            }

        /* ── Media Queries ── */
        @@media (max-width: 1366px) {
