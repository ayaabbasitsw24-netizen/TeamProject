<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>الرئيسية — عشاق الدراسة | لوحة التدريسي</title>
    <meta name="description" content="لوحة التحكم الرئيسية للتدريسي - عشاق الدراسة">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&display=swap" rel="stylesheet">
    <style>
        /* ============================================================
           إنجاز بلس — Design System (app.css)
           A premium, unified design system for STMS MPA
           ============================================================ */

        /* ─── THEMES ─────────────────────────────────────────────── */
        .theme-blue {
            --primary: #3b82f6;
            --primary-light: #60a5fa;
            --primary-dark: #1e40af;
            --accent-bg: rgba(59, 130, 246, 0.1);
            --sidebar-bg: #dbeafe;
            --sidebar-text: #0c2d6b;
            --bg: #eff6ff;
            --card-bg: #f0f9ff;
            --text-main: #0c2d6b;
            --text-muted: #3b82f6;
            --border: #bfdbfe;
            --shadow-sm: 0 2px 8px rgba(59, 130, 246, .08);
            --shadow-md: 0 6px 24px rgba(59, 130, 246, .12);
            --shadow-lg: 0 12px 45px rgba(59, 130, 246, .15);
        }

        .theme-purple {
            --primary: #a78bfa;
            --primary-light: #c4b5fd;
            --primary-dark: #7e22ce;
            --accent-bg: rgba(167, 139, 250, 0.1);
            --sidebar-bg: #f3e8ff;
            --sidebar-text: #5b21b6;
            --bg: #faf5ff;
            --card-bg: #fef3ff;
            --text-main: #5b21b6;
            --text-muted: #a78bfa;
            --border: #e9d5ff;
            --shadow-sm: 0 2px 8px rgba(167, 139, 250, .08);
            --shadow-md: 0 6px 24px rgba(167, 139, 250, .12);
            --shadow-lg: 0 12px 45px rgba(167, 139, 250, .15);
        }

        .theme-green {
            --primary: #10b981;
            --primary-light: #6ee7b7;
            --primary-dark: #047857;
            --accent-bg: rgba(16, 185, 129, 0.1);
            --sidebar-bg: #d1fae5;
            --sidebar-text: #064e3b;
            --bg: #f0fdf4;
            --card-bg: #f7fefc;
            --text-main: #064e3b;
            --text-muted: #10b981;
            --border: #a7f3d0;
            --shadow-sm: 0 2px 8px rgba(16, 185, 129, .08);
            --shadow-md: 0 6px 24px rgba(16, 185, 129, .12);
            --shadow-lg: 0 12px 45px rgba(16, 185, 129, .15);
        }

        .theme-dark {
            --primary: #818cf8;
            --primary-light: #a5b4fc;
            --primary-dark: #4f46e5;
            --accent-bg: rgba(129, 140, 248, 0.12);
            --sidebar-bg: #111827;
            --sidebar-text: #f3f4f6;
            --bg: #1f2937;
            --card-bg: #374151;
            --text-main: #f3f4f6;
            --text-muted: #d1d5db;
            --border: #4b5563;
            --shadow-sm: 0 2px 8px rgba(0, 0, 0, .3);
            --shadow-md: 0 6px 24px rgba(0, 0, 0, .4);
            --shadow-lg: 0 12px 45px rgba(0, 0, 0, .55);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Tajawal', sans-serif;
            background: var(--bg);
            color: var(--text-main);
            min-height: 100vh;
            direction: rtl;
            transition: background 0.35s, color 0.35s;
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        img {
            max-width: 100%;
            display: block;
        }

        .app-wrapper {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 260px;
            background: var(--sidebar-bg);
            border-left: 2px solid var(--border);
            display: flex;
            flex-direction: column;
            position: fixed;
            right: 0;
            top: 0;
            height: 100vh;
            z-index: 200;
            transition: transform 0.3s cubic-bezier(.4, 0, .2, 1), box-shadow 0.3s;
            box-shadow: -4px 0 20px rgba(0, 0, 0, .12);
            overflow-y: auto;
        }

        .sidebar-header {
            padding: 24px 20px 18px;
            border-bottom: 2px solid var(--border);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .logo-icon {
            font-size: 1.6rem;
        }

        .logo-text {
            font-size: 1.15rem;
            font-weight: 700;
            color: var(--primary);
            letter-spacing: -0.3px;
        }

        .sidebar-nav {
            flex: 1;
            padding: 12px 10px;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 14px 18px;
            border-radius: 12px;
            margin-bottom: 6px;
            color: var(--sidebar-text);
            font-size: 0.98rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
        }

            .nav-item i {
                width: 20px;
                text-align: center;
                font-size: 1rem;
                opacity: .7;
                transition: opacity .2s;
            }

            .nav-item:hover {
                background: var(--accent-bg);
                color: var(--primary);
            }

                .nav-item:hover i {
                    opacity: 1;
                    color: var(--primary);
                }

            .nav-item.active {
                background: linear-gradient(135deg, var(--primary), var(--primary-dark));
                color: #fff;
                font-weight: 600;
                box-shadow: 0 4px 14px ;
            }

                .nav-item.active i {
                    opacity: 1;
                    color: #fff;
                }

        .sidebar-footer {
            padding: 16px 18px;
            border-top: 2px solid var(--border);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .user-mini {
            flex: 1;
            display: flex;
            align-items: center;
            gap: 10px;
            overflow: hidden;
        }

        .user-mini-avatar {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            background: var(--accent-bg);
            border: 2px solid var(--primary-light);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            flex-shrink: 0;
            overflow: hidden;
        }

            .user-mini-avatar img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .user-mini-info {
            overflow: hidden;
        }

            .user-mini-info span {
                font-size: .85rem;
                font-weight: 600;
                display: block;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

            .user-mini-info small {
                font-size: .73rem;
                color: var(--text-muted);
            }

        .logout-btn {
            background: none;
            border: none;
            cursor: pointer;
            color: var(--text-muted);
            font-size: 1rem;
            padding: 6px 8px;
            border-radius: 8px;
            transition: all 0.2s;
        }

            .logout-btn:hover {
                background: #fee2e2;
                color: #ef4444;
            }

        .main-wrapper {
            margin-right: 260px;
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .top-header {
            background: var(--card-bg);
            border-bottom: 2px solid var(--border);
            padding: 16px 28px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: var(--shadow-md);
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .page-title {
            font-size: 1.2rem;
            font-weight: 700;
            color: var(--text-main);
        }

        .mobile-toggle {
            display: none;
            background: none;
            border: none;
            cursor: pointer;
            font-size: 1.2rem;
            color: var(--text-muted);
            padding: 4px 6px;
            border-radius: 8px;
        }

        .header-right {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .header-user {
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .header-user span {
                font-size: .9rem;
                color: var(--text-muted);
            }

        .header-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: var(--accent-bg);
            border: 2px solid var(--primary-light);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            overflow: hidden;
        }

        .content-area {
            flex: 1;
            padding: 20px 24px;
            overflow-y: auto;
        }

        .page {
            animation: fadeIn 0.35s ease;
        }

        @@keyframes fadeIn {
            from

        {
            opacity: 0;
            transform: translateY(12px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }

        .card {
            background: var(--card-bg);
            border-radius: 18px;
            border: 2px solid var(--border);
            box-shadow: var(--shadow-md);
            transition: transform 0.25s, box-shadow 0.25s;
        }

            .card:hover {
                transform: translateY(-4px);
                box-shadow: var(--shadow-md);
            }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: #fff;
            border: none;
            padding: 10px 22px;
            border-radius: 12px;
            font-family: inherit;
            font-size: .95rem;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            box-shadow: 0 4px 14px rgba(0, 0, 0, 0.15);
            transition: all 0.25s;
        }

            .btn-primary:hover {
                transform: translateY(-2px);
                filter: brightness(1.1);
                box-shadow: 0 8px 22px rgba(0, 0, 0, 0.22);
            }

            .btn-primary:active {
                transform: translateY(0);
            }

        .toast {
            position: fixed;
            bottom: 28px;
            left: 50%;
            transform: translateX(-50%) translateY(120px);
            background: #1e293b;
            color: #fff;
            padding: 12px 26px;
            border-radius: 30px;
            font-size: .9rem;
            z-index: 9999;
            transition: transform .35s cubic-bezier(.175, .885, .32, 1.275);
            white-space: nowrap;
            pointer-events: none;
            box-shadow: 0 8px 30px rgba(0, 0, 0, .2);
        }

            .toast.show {
                transform: translateX(-50%) translateY(0);
            }

            .toast.success {
                background: #16a34a;
            }

            .toast.error {
                background: #dc2626;
            }

            .toast.info {
                background: var(--primary);
            }

        .sidebar-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, .45);
            z-index: 150;
            backdrop-filter: blur(3px);
        }

            .sidebar-overlay.active {
                display: block;
            }

        /* Home Page Styles */
        .welcome-banner {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 60%, var(--primary-dark) 100%);
            background-size: 200% 200%;
            animation: gradientShift 8s ease infinite;
            border-radius: 22px;
            padding: 32px 36px;
            color: #fff;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 28px;
            box-shadow: var(--shadow-lg);
        }

        @@keyframes gradientShift {
            0%

        {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }

        100% {
            background-position: 0% 50%;
        }

        }

        .welcome-text h2 {
            font-size: 1.6rem;
            margin-bottom: 6px;
            font-weight: 700;
        }

        .welcome-text p {
            opacity: .85;
            font-size: .95rem;
        }

        .welcome-emoji {
            font-size: 4rem;
            filter: drop-shadow(0 4px 10px rgba(0, 0, 0, .2));
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 18px;
            margin-bottom: 28px;
        }

        .stat-card {
            background: var(--card-bg);
            border-radius: 18px;
            padding: 24px 22px;
            display: flex;
            align-items: center;
            gap: 16px;
            border: 2px solid var(--border);
            box-shadow: var(--shadow-md);
            transition: transform 0.25s, box-shadow 0.25s;
        }

            .stat-card:hover {
                transform: translateY(-5px);
                box-shadow: var(--shadow-md);
            }

        .stat-icon {
            width: 52px;
            height: 52px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
            flex-shrink: 0;
        }

            .stat-icon.blue {
                background: #e8f0fe;
                color: #4e7bef;
            }

            .stat-icon.purple {
                background: #f0eaff;
                color: #7c50e0;
            }

            .stat-icon.green {
                background: #e2f8ee;
                color: #1db27a;
            }

            .stat-icon.gold {
                background: #fef9e7;
                color: #f59e0b;
            }

                .stat-icon.gold i {
                    animation: pulse 2s infinite;
                }

        @@keyframes pulse {
            0%, 100%

        {
            transform: scale(1);
        }

        50% {
            transform: scale(1.2);
            filter: drop-shadow(0 0 6px rgba(245, 158, 11, .5));
        }

        }

        .stat-number {
            display: block;
            font-size: 2rem;
            font-weight: 800;
            line-height: 1;
        }

        .stat-label {
            font-size: .8rem;
            color: var(--text-muted);
            margin-top: 4px;
            display: block;
        }

        .home-sections {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 22px;
        }

        .home-section {
            background: var(--card-bg);
            border-radius: 18px;
            padding: 26px;
            border: 2px solid var(--border);
            box-shadow: var(--shadow-md);
        }

            .home-section h3 {
                font-size: 1rem;
                font-weight: 700;
                margin-bottom: 18px;
                display: flex;
                align-items: center;
                gap: 8px;
                color: var(--text-main);
            }

        .empty-state {
            text-align: center;
            padding: 32px 16px;
            color: var(--text-muted);
            font-size: .9rem;
        }

        .task-item.mini {
            padding: 10px 14px;
            border-radius: 10px;
            flex-wrap: nowrap;
            gap: 10px;
            background: var(--bg);
            border: 1px solid var(--border);
            margin-bottom: 8px;
            display: flex;
            align-items: center;
        }

            .task-item.mini span {
                font-size: .88rem;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
                flex: 1;
            }

        .quick-actions {
            margin-top: 24px;
        }

            .quick-actions h3 {
                font-size: 1rem;
                font-weight: 700;
                margin-bottom: 14px;
                display: flex;
                align-items: center;
                gap: 8px;
            }

        .qa-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
            gap: 12px;
        }

        .qa-card {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 18px 12px;
            border-radius: 14px;
            background: var(--card-bg);
            border: 1.5px solid var(--border);
            text-decoration: none;
            color: var(--text-main);
            font-weight: 600;
            font-size: .9rem;
            transition: transform .2s, box-shadow .2s, border-color .2s;
            cursor: pointer;
        }

            .qa-card:hover {
                transform: translateY(-3px);
                box-shadow: 0 8px 24px rgba(0, 0, 0, .1);
                border-color: var(--primary);
            }

            .qa-card i {
                font-size: 1.4rem;
                color: var(--primary);
            }

        @@media (max-width: 768px) {
            .sidebar

        {
            transform: translateX(100%);
        }

        .sidebar.open {
            transform: translateX(0);
            box-shadow: -8px 0 40px rgba(0, 0, 0, .2);
        }

        .main-wrapper {
            margin-right: 0;
        }

        .mobile-toggle {
            display: flex;
        }

        .content-area {
            padding: 18px 16px;
        }

        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .home-sections {
            grid-template-columns: 1fr;
        }

        .welcome-emoji {
            font-size: 3rem;
        }

        }
    </style>
</head>

<body class="theme-purple">
    <div class="sidebar-overlay"></div>
    <div class="app-wrapper">
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <div class="logo">
                    <span class="logo-icon">📚</span>
                    <span class="logo-text">عشاق الدراسة</span>
                </div>
            </div>



            <nav class="sidebar-nav">
                <a href="Dashboard" class="nav-item active" data-page="home">
                    <i class="fas fa-home"></i> <span>الرئيسية</span>
                </a>
                <a href="DoctorSchedule" class="nav-item" data-page="schedule">
                    <i class="fas fa-calendar-alt"></i> <span>المخطط الأسبوعي</span>
                </a>
                <a href="subjects" class="nav-item" data-page="subjects">
                    <i class="fas fa-video"></i> <span>المحاضرات</span>
                </a>
                <a href="assignment" class="nav-item" data-page="assignment">
                    <i class="fas fa-tasks"></i> <span>التكاليف</span>
                </a>
                <a href="chat" class="nav-item" data-page="chat">
                    <i class="fas fa-users"></i> <span>ركن الدردشة  </span>
                </a>
               
                <a href="profile" class="nav-item" data-page="profile">
                    <i class="fas fa-user-circle"></i> <span>ملفي الشخصي</span>
                </a>
            </nav>


            

            <div class="sidebar-footer">
                <div class="user-mini">
                    <div class="user-mini-avatar" id="sidebar-avatar">👨‍🏫</div>
                    <div class="user-mini-info">
                        <span id="sidebar-name">الدكتور</span>
                        <small id="sidebar-role">تدريسي</small>
                    </div>
                </div>
                <button class="logout-btn" id="logout-btn" title="تسجيل الخروج">
                    <i class="fas fa-sign-out-alt"></i>
                </button>
            </div>
        </aside>

        <div class="main-wrapper">
            <header class="top-header">
                <div class="header-left">
                    <button class="mobile-toggle" id="mobile-toggle">
                        <i class="fas fa-bars"></i>
                    </button>
                    <h1 class="page-title" id="page-title">لوحة التحكم</h1>
                </div>
                <div class="header-right">
                    <div class="header-user">
                        <span id="header-name">مرحباً!</span>
                        <div class="header-avatar" id="header-avatar">👨‍🏫</div>
                    </div>
                </div>
            </header>

            <main class="content-area">
                <div class="page active" id="page-home">
                    <!-- بانر الترحيب -->
                    <div class="welcome-banner">
                        <div class="welcome-text">
                            <h2>أهلاً وسهلاً، د. <span id="home-username">المحاضر</span>! 👨‍🏫</h2>
                            <p>إدارة محاضراتك وطلابك بسهولة</p>
                            <span id="role-badge" class="role-badge-big"></span>
                        </div>
                        <div class="welcome-emoji">📚</div>
                    </div>

                    <!-- إحصائيات -->
                    <div class="stats-grid">
                        <div class="stat-card">
                            <div class="stat-icon blue"><i class="fas fa-users"></i></div>
                            <div class="stat-info">
                                <span class="stat-number" id="students-count">0</span>
                                <span class="stat-label">طالب مسجل</span>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon purple"><i class="fas fa-video"></i></div>
                            <div class="stat-info">
                                <span class="stat-number" id="lectures-count">0</span>
                                <span class="stat-label">محاضرة مرفوعة</span>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon green"><i class="fas fa-tasks"></i></div>
                            <div class="stat-info">
                                <span class="stat-number" id="assignments-count">0</span>
                                <span class="stat-label">تكليف معطى</span>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon gold"><i class="fas fa-comments"></i></div>
                            <div class="stat-info">
                                <span class="stat-number" id="messages-count">0</span>
                                <span class="stat-label">رسائل غير مقروءة</span>
                            </div>
                        </div>
                    </div>

                    <!-- الأقسام الرئيسية -->
                    <div class="home-sections">
                        <div class="home-section">
                            <h3><i class="fas fa-video"></i> آخر المحاضرات</h3>
                            <div id="recent-lectures">
                                <p class="empty-state">لم ترفع أي محاضرات بعد! 🎥</p>
                            </div>
                        </div>

                        <div class="home-section">
                            <h3><i class="fas fa-tasks"></i> التكاليف المعطاة</h3>
                            <div id="assignments-list">
                                <p class="empty-state">لم تضيف أي تكاليف بعد. ابدأ الآن! 📋</p>
                            </div>
                        </div>
                    </div>

                    <!-- إجراءات سريعة -->
                    <div class="quick-actions">
                        <h3><i class="fas fa-lightning-bolt"></i> إجراءات سريعة</h3>
                        <div class="qa-grid">
                            <a href="DoctorSchedule.html" class="qa-card">
                                <i class="fas fa-calendar-alt"></i>
                                <span>المخطط الأسبوعي</span>
                            </a>
                            <a href="lectures.html" class="qa-card">
                                <i class="fas fa-upload"></i>
                                <span>رفع محاضرة</span>
                            </a>
                            <a href="assignments.html" class="qa-card">
                                <i class="fas fa-plus-circle"></i>
                                <span>إضافة تكليف</span>
                            </a>
                           
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <div id="toast" class="toast"></div>


    <script>
        function getLocalStorage(key, fallback = {}) {
            try { return JSON.parse(localStorage.getItem(key) || JSON.stringify(fallback)); }
            catch { return fallback; }
        }

        document.addEventListener('DOMContentLoaded', () => {
            const user = getLocalStorage('enjaz_user', { name: 'الدكتور' });
            document.getElementById('sidebar-name').textContent = user.name;
            document.getElementById('header-name').textContent = `مرحباً، د. ${user.name}!`;
            document.getElementById('home-username').textContent = user.name;
            document.getElementById('sidebar-avatar').textContent = user.name.charAt(0).toUpperCase();
            document.getElementById('header-avatar').textContent = user.name.charAt(0).toUpperCase();

            const profile = getLocalStorage('enjaz_profile', { theme: 'purple' });
            const themeClass = profile.theme ? `theme-${profile.theme}` : 'theme-purple';
            document.body.className = themeClass;

            setupEvents(user);
        });

        function setupEvents(user) {
            document.getElementById('logout-btn')?.addEventListener('click', () => {
                localStorage.removeItem('enjaz_user');
                localStorage.removeItem('enjaz_token');
                window.location.href = 'Login.html';
            });

            document.getElementById('mobile-toggle')?.addEventListener('click', () => {
                document.getElementById('sidebar').classList.toggle('open');
                document.querySelector('.sidebar-overlay')?.classList.toggle('active');
            });

            document.querySelector('.sidebar-overlay')?.addEventListener('click', () => {
                document.getElementById('sidebar').classList.remove('open');
                document.querySelector('.sidebar-overlay')?.classList.remove('active');
            });
        }

        // Authentication check
        (function () {
            const user = localStorage.getItem('enjaz_user');
            const token = localStorage.getItem('enjaz_token');

            if (!user || !token) {
                window.location.href = 'Login.html';
            }
        })();
    </script>
</body>

</html>
