                        </div>
                    </div>

                    <!-- إجراءات سريعة حسب الدور -->
                    <div class="quick-actions">
                        <h3><i class="fas fa-bolt"></i> إجراءات سريعة</h3>
                        <div class="qa-grid">
                            <!-- مشترك -->
                            <a href="tasks.html" class="qa-card student-only">
                                <i class="fas fa-plus-circle"></i>
                                <span>إضافة مهمة</span>
                            </a>
                            <a href="schedule.html" class="qa-card">
                                <i class="fas fa-calendar-plus"></i>
                                <span>الجدول الأسبوعي</span>
                            </a>
                            <a href="subjects.html" class="qa-card">
                                <i class="fas fa-book-open"></i>
                                <span>المواد الدراسية</span>
                            </a>
                            <!-- دكتور / أدمن -->
                            <a href="subjects.html" class="qa-card doctor-only" style="display:none;">
                                <i class="fas fa-file-circle-plus"></i>
                                <span>رفع محاضرة</span>
                            </a>
                            <a href="admin.html" class="qa-card admin-only"
                               style="display:none;background:linear-gradient(135deg,#7c3aed,#a855f7);">
                                <i class="fas fa-users-cog"></i>
                                <span>إدارة المستخدمين</span>
                            </a>
                        </div>
