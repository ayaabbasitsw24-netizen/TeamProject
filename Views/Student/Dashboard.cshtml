                </div>
            </main>
        </div>
    </div>

    <div id="toast" class="toast"></div>

    <!-- ═══ HOME PAGE STANDALONE JS ═══ -->
    <script src="auth-guard.js"></script>
    <script>
        // بيانات محاكاة - localStorage fallback
        function getLocalStorage(key, fallback = {}) {
            try { return JSON.parse(localStorage.getItem(key) || JSON.stringify(fallback)); }
            catch { return fallback; }
        }

        function setLocalStorage(key, value) {
            try { localStorage.setItem(key, JSON.stringify(value)); }
            catch { console.warn(`Failed to save ${key}`); }
        }

        // معالج الأخطاء والتحقق من المستخدم (fallback بدون Firebase)
        function readyPage() {
            // حاول قراءة البيانات من كلا الـ keys
            let user = null;
            const userJson = localStorage.getItem('enjaz_user') || localStorage.getItem('sl_user');

            if (userJson) {
                try {
                    user = JSON.parse(userJson);
                } catch (e) {
                    console.warn('خطأ في قراءة بيانات المستخدم:', e);
                }
            }

            if (!user) {
                user = {
                    id: 'default-user',
                    name: 'المستخدم',
                    email: 'user@example.com',
                    role: 'student'
                };
            }

            const profile = getLocalStorage('enjaz_profile', {
                name: user.name,
                avatar: '👤',
                theme: 'purple'
            });

            // تطبيق المظهر
            const themeClass = profile.theme ? `theme-${profile.theme}` : 'theme-purple';
            document.body.className = themeClass;

            // تحديث الأسماء
            document.getElementById('sidebar-name').textContent = user.name;
            document.getElementById('header-name').textContent = `مرحباً، ${user.name}!`;
            document.getElementById('home-username').textContent = user.name;
            document.getElementById('sidebar-avatar').textContent = profile.avatar;
            document.getElementById('header-avatar').textContent = profile.avatar;

            // شارة الدور
            const badgeMap = {
                admin: { text: '🔐 مشرف النظام', color: '#7c3aed' },
                doctor: { text: '👨‍🏫 تدريسي', color: '#06b6d4' },
                student: { text: '🎓 طالب', color: '#22c55e' }
            };
            const badge = badgeMap[user.role];
            const badgeEl = document.getElementById('role-badge');
            if (badgeEl && badge) {
                badgeEl.textContent = badge.text;
                badgeEl.style.cssText = `display:inline-block; padding:3px 14px; border-radius:20px; background:${badge.color}22; color:${badge.color}; font-size:.8rem; font-weight:700; margin-top:8px; border:1px solid ${badge.color}44;`;
            }

            const sidebarRole = document.getElementById('sidebar-role');
            if (sidebarRole) sidebarRole.textContent = badge?.text || user.role;

            // ========== التحكم في الصلاحيات ==========
            // إظهار/إخفاء العناصر بناءً على الدور
            document.querySelectorAll('.student-only').forEach(el => {
                el.style.display = user.role === 'student' ? '' : 'none';
            });
            document.querySelectorAll('.doctor-only').forEach(el => {
                el.style.display = user.role === 'doctor' ? '' : 'none';
            });
            document.querySelectorAll('.admin-only').forEach(el => {
                el.style.display = user.role === 'admin' ? '' : 'none';
            });

            // تحميل البيانات
            const tasks = getLocalStorage('enjaz_tasks', []);
            const points = parseInt(localStorage.getItem('enjaz_points') || '0');
            const sched = getLocalStorage('enjaz_schedule', []);

            // إذا كان دكتور، اخفِ بيانات الطالب
            if (user.role === 'doctor') {
                document.getElementById('leaderboard-section').style.display = 'none';
                // عدّل الإحصائيات للدكتور
                document.getElementById('total-tasks-done').parentElement.innerHTML = `
                    <span class="stat-number" id="students-count">0</span>
                    <span class="stat-label">طالب مسجل</span>
                `;
                document.getElementById('pending-tasks').parentElement.innerHTML = `
                    <span class="stat-number" id="lectures-count">0</span>
                    <span class="stat-label">محاضرة مرفوعة</span>
                `;
                document.getElementById('points-display').textContent = tasks.length; // عدد المهام التي أنشأها
                document.getElementById('points-display').parentElement.querySelector('.stat-label').textContent = 'مهمة منشأة';
            } else {
                // إحصائيات الطالب العادية
                document.getElementById('total-tasks-done').textContent = tasks.filter(t => t.done).length;
                document.getElementById('pending-tasks').textContent = tasks.filter(t => !t.done).length;
                document.getElementById('points-display').textContent = points;
            }

            // عرض البيانات
            renderTodaySchedule(sched);
            if (user.role === 'student') {
                renderRecentTasks(tasks.slice(0, 3));
                renderLeaderboard(points, user.name);
            } else if (user.role === 'doctor') {
                renderLecturesList([]);
                renderStudentsList([]);
            }

            // أحداث
            setupEvents(user);
        }

        function renderTodaySchedule(sched) {
            const el = document.getElementById('today-schedule');
            if (!el) return;
            const days = ['الأحد', 'الإثنين', 'الثلاثاء', 'الأربعاء', 'الخميس', 'الجمعة', 'السبت'];
            const today = days[new Date().getDay()];
            const items = sched.filter(s => s.day === today);
            if (!items.length) return;
            el.innerHTML = items.map(s => `
                <div class="schedule-mini-item">
                    <strong>${s.subject}</strong>
                    <small><i class="fas fa-clock"></i> ${s.time} • <i class="fas fa-location-dot"></i> ${s.location || 'غير محدد'}</small>
                </div>
            `).join('');
        }

        function renderRecentTasks(tasks) {
            const el = document.getElementById('recent-tasks-list');
            if (!el || !tasks.length) return;
            el.innerHTML = tasks.map(t => `
                <div class="task-item mini">
                    <div class="task-check ${t.done ? 'done' : ''}">
                        ${t.done ? '<i class="fas fa-check" style="font-size:.6rem;"></i>' : ''}
                    </div>
                    <span>${t.title}</span>
                    <small style="margin-right:auto;color:var(--text-muted);">${t.subject || ''}</small>
                </div>
            `).join('');
        }

        function renderLeaderboard(userPoints, userName) {
            const el = document.getElementById('leaderboard-list');
            if (!el) return;
            const leaders = [
                { name: 'أحمد علي', points: 1250, avatar: 'A' },
                { name: 'سارة محمود', points: 980, avatar: 'S' },
                { name: 'محمد أحمد', points: 850, avatar: 'M' },
                { name: 'ليلى خالد', points: 720, avatar: 'L' }
            ];
            leaders.push({ name: userName, points: userPoints, avatar: '👤', isMe: true });
            leaders.sort((a, b) => b.points - a.points);

            el.innerHTML = leaders.slice(0, 5).map((l, i) => {
                const rankClass = i === 0 ? 'rank-1' : i === 1 ? 'rank-2' : i === 2 ? 'rank-3' : 'rank-other';
                return `
                    <div class="leaderboard-item" style="${l.isMe ? 'border-color:var(--primary); background:rgba(124,80,224,0.05);' : ''}">
                        <div class="rank-badge ${rankClass}">${i + 1}</div>
                        <div class="leader-avatar">${l.avatar}</div>
                        <div class="leader-name">${l.name} ${l.isMe ? '(أنت)' : ''}</div>
                        <div class="leader-points">${l.points}</div>
                    </div>
                `;
            }).join('');
        }

        // ========== دوال خاصة بالدكتور ==========
        function renderLecturesList(lectures) {
            const el = document.getElementById('lectures-list');
            if (!el) return;
            if (!lectures.length) {
                el.innerHTML = '<p class="empty-state">لم ترفع أي محاضرات بعد. ابدأ الآن! 🎥</p>';
                return;
            }
            el.innerHTML = lectures.map(l => `
                <div class="task-item mini" style="border-right:3px solid var(--primary);">
                    <i class="fas fa-video" style="color:var(--primary); margin-right:4px;"></i>
                    <span>${l.title}</span>
                    <small style="margin-right:auto; color:var(--text-muted);">${l.subject}</small>
                </div>
            `).join('');
        }

        function renderStudentsList(students) {
            const el = document.getElementById('students-list');
            if (!el) return;
            if (!students.length) {
                el.innerHTML = '<p class="empty-state">لا توجد طلاب مسجلون بعد 👥</p>';
                return;
            }
            el.innerHTML = students.map((s, i) => {
                const rankClass = 'rank-other';
                return `
                    <div class="leaderboard-item">
                        <div class="rank-badge ${rankClass}">${i + 1}</div>
                        <div class="leader-avatar">${s.avatar}</div>
                        <div class="leader-name">${s.name}</div>
                        <small style="margin-right:auto; color:var(--text-muted);">${s.email}</small>
                    </div>
                `;
            }).join('');
        }

        function setupEvents(user) {
            document.getElementById('logout-btn')?.addEventListener('click', () => {
                localStorage.removeItem('enjaz_user');
                localStorage.removeItem('enjaz_token');
                location.href = 'login.html';
            });

            document.getElementById('mobile-toggle')?.addEventListener('click', () => {
                document.getElementById('sidebar').classList.toggle('open');
                document.querySelector('.sidebar-overlay')?.classList.toggle('active');
            });

            document.querySelector('.sidebar-overlay')?.addEventListener('click', () => {
                document.getElementById('sidebar').classList.remove('open');
                document.querySelector('.sidebar-overlay')?.classList.remove('active');
            });
        }

        document.addEventListener('DOMContentLoaded', () => {
            readyPage();
            // تحديث الصورة الشخصية
            if (typeof updateAvatar === 'function') updateAvatar();
        });
    </script>

    <!-- Styles إضافية -->
    <style>
        .role-badge-big {
            display: none;
        }
    </style>

    <!-- Check Authentication -->
    <script>
        (function () {
            const user = localStorage.getItem('enjaz_user') || localStorage.getItem('sl_user');
            const token = localStorage.getItem('enjaz_token') || localStorage.getItem('sl_token');

            if (!user || !token) {
                window.location.href = 'Login.html';
            } else {
                try {
                    const userData = JSON.parse(user);
                    if (userData.role === 'doctor') {
                        window.location.href = 'DoctorHome.html';
                    }
                } catch (e) {
                    window.location.href = 'Login.html';
                }
            }
        })();
    </script>
</body>

</html>